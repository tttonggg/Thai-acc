{
  "info": {
    "_postman_id": "thai-accounting-erp-api-v1-enhanced",
    "name": "Thai Accounting ERP API - Complete Collection",
    "description": "Complete API collection for Thai Accounting ERP System with all modules including Authentication, Accounts, Invoices, Receipts, Payments, Journal Entries, Customers, Vendors, Products, Inventory, Banking, Fixed Assets, Payroll, Petty Cash, WHT, Reports, and Settings. Includes environment variables, pre-request scripts, and test scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": {
      "major": 1,
      "minor": 1,
      "patch": 0
    }
  },
  "item": [
    {
      "name": "🔐 Authentication",
      "description": "Authentication endpoints for user login and session management",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.test('Login successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "if (jsonData.sessionToken) {",
                  "    pm.environment.set('sessionToken', jsonData.sessionToken);",
                  "}",
                  "if (jsonData.user) {",
                  "    pm.environment.set('userId', jsonData.user.id);",
                  "    pm.environment.set('userRole', jsonData.user.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{email}}\", \"password\": \"{{password}}\", \"redirect\": false}"
            },
            "url": {"raw": "{{baseUrl}}/api/auth/callback/credentials", "host": ["{{baseUrl}}"], "path": ["api", "auth", "callback", "credentials"]}
          }
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/auth/session", "host": ["{{baseUrl}}"], "path": ["api", "auth", "session"]}
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/auth/signout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "signout"]}
          }
        }
      ]
    },
    {
      "name": "📊 Accounts",
      "item": [
        {
          "name": "List Accounts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/accounts?page={{page}}&limit={{limit}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts"],
              "query": [
                {"key": "page", "value": "{{page}}"},
                {"key": "limit", "value": "{{limit}}"},
                {"key": "type", "value": "{{accountType}}"}
              ]
            }
          }
        },
        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"code\": \"{{accountCode}}\", \"name\": \"{{accountName}}\", \"type\": \"{{accountType}}\"}"
            },
            "url": {"raw": "{{baseUrl}}/api/accounts", "host": ["{{baseUrl}}"], "path": ["api", "accounts"]}
          }
        }
      ]
    },
    {
