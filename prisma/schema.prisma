// Thai Accounting ERP System - Prisma Schema
// โปรแกรมบัญชีมาตรฐานไทย
// Monetary values are stored in Satang (สตางค์) - 1/100 of Baht

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// ข้อมูลบริษัท / Company Profile
// ============================================
model Company {
  id              String          @id @default(cuid())
  name            String // ชื่อบริษัท
  nameEn          String? // ชื่อภาษาอังกฤษ
  taxId           String? // เลขประจำตัวผู้เสียภาษี
  branchCode      String? // รหัสสาขา
  address         String? // ที่อยู่
  subDistrict     String? // แขวง/ตำบล
  district        String? // เขต/อำเภอ
  province        String? // จังหวัด
  postalCode      String? // รหัสไปรษณีย์
  phone           String? // โทรศัพท์
  fax             String? // โทรสาร
  email           String? // อีเมล
  website         String? // เว็บไซต์
  logo            String? // โลโก้
  fiscalYearStart Int             @default(1) // เริ่มปีบัญชี (เดือน)
  metadata        Json? // ข้อมูลส่วนขยาย
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  systemSettings  SystemSettings?
}

// ============================================
// ตั้งค่าระบบ / System Settings
// ============================================
model SystemSettings {
  id               String   @id @default(cuid())
  companyId        String   @unique
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vatRate          Float    @default(7) // อัตราภาษีมูลค่าเพิ่ม (%)
  whtPnd53Service  Float    @default(3) // อัตราภาษีหัก ณ ที่จ่าย ค่าบริการ (%)
  whtPnd53Rent     Float    @default(5) // อัตราภาษีหัก ณ ที่จ่าย ค่าเช่า (%)
  whtPnd53Prof     Float    @default(3) // อัตราภาษีหัก ณ ที่จ่าย ค่าบริการวิชาชีพ (%)
  whtPnd53Contract Float    @default(1) // อัตราภาษีหัก ณ ที่จ่าย ค่าจ้างทำของ (%)
  whtPnd53Advert   Float    @default(2) // อัตราภาษีหัก ณ ที่จ่าย ค่าโฆษณา (%)
  metadata         Json? // ข้อมูลส่วนขยาย
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ============================================
// ผังบัญชี / Chart of Accounts
// ============================================
model ChartOfAccount {
  id           String           @id @default(cuid())
  code         String           @unique // รหัสบัญชี (1000, 1100, 1110, etc.)
  name         String // ชื่อบัญชี
  nameEn       String? // ชื่อภาษาอังกฤษ
  type         AccountType // ประเภทบัญชี
  level        Int              @default(1) // ระดับ (1-4)
  parentId     String? // บัญชีแม่
  parent       ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     ChartOfAccount[] @relation("AccountHierarchy")
  isDetail     Boolean          @default(true) // เป็นบัญชีรายละเอียดหรือไม่
  isSystem     Boolean          @default(false) // เป็นบัญชีระบบหรือไม่
  isActive     Boolean          @default(true)
  notes        String? // หมายเหตุ
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  journalLines JournalLine[]
  budgets      Budget[]

  @@index([parentId])
}

enum AccountType {
  ASSET // สินทรัพย์ (1xxx)
  LIABILITY // หนี้สิน (2xxx)
  EQUITY // ทุน (3xxx)
  REVENUE // รายได้ (4xxx)
  EXPENSE // ค่าใช้จ่าย (5xxx)
}

// ============================================
// บันทึกบัญชี / Journal Entry
// ============================================
model JournalEntry {
  id                String             @id @default(cuid())
  entryNo           String             @unique // เลขที่บันทึก
  date              DateTime // วันที่
  description       String? // รายการ
  reference         String? // เอกสารอ้างอิง
  documentType      String? // ประเภทเอกสาร
  documentId        String? // ID เอกสารต้นทาง
  totalDebit        Int                @default(0) // รวมเดบิต (สตางค์)
  totalCredit       Int                @default(0) // รวมเครดิต (สตางค์)
  status            EntryStatus        @default(DRAFT)
  isAdjustment      Boolean            @default(false) // รายการปรับปรุง
  isReversing       Boolean            @default(false) // รายการย้อนกลับ
  reversingId       String? // ID ของรายการที่ย้อน
  createdById       String? // ผู้สร้าง
  approvedById      String? // ผู้อนุมัติ
  approvedAt        DateTime? // วันที่อนุมัติ
  idempotencyKey    String?            @unique // ✅ FIXED: Prevent duplicate journal entries
  notes             String? // หมายเหตุ
  isActive          Boolean            @default(true)
  deletedAt         DateTime?
  deletedBy         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lines             JournalLine[]
  invoices          Invoice[]          @relation("InvoiceJournal")
  purchaseInvoices  PurchaseInvoice[]  @relation("PurchaseInvoiceJournal")
  receipts          Receipt[]          @relation("ReceiptJournal")
  payments          Payment[]          @relation("PaymentJournal")
  creditNotes       CreditNote[]       @relation("CreditNoteJournal")
  debitNotes        DebitNote[]        @relation("DebitNoteJournal")
  payrollRuns       PayrollRun[]       @relation("PayrollRunJournal")
  cheques           Cheque[]           @relation("ChequeJournal")
  pettyCashVouchers PettyCashVoucher[] @relation("PettyCashVoucherJournal")
  stockTakes        StockTake[]        @relation("StockTakeJournal")

  @@index([createdById])
  @@index([approvedById])
  @@index([reversingId])
  @@index([deletedAt])
}

model JournalLine {
  id          String         @id @default(cuid())
  entryId     String
  entry       JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lineNo      Int // ลำดับ
  accountId   String
  account     ChartOfAccount @relation(fields: [accountId], references: [id])
  description String? // รายการ
  debit       Int            @default(0) // เดบิต (สตางค์) - CHECK: >= 0
  credit      Int            @default(0) // เครดิต (สตางค์) - CHECK: >= 0
  // PostgreSQL CHECK: (debit = 0 AND credit >= 0) OR (debit >= 0 AND credit = 0)
  reference   String? // เอกสารอ้างอิง
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([entryId])
  @@index([accountId])
}

enum EntryStatus {
  DRAFT // ร่าง
  POSTED // ลงบัญชีแล้ว
  REVERSED // ย้อนกลับแล้ว
}

// ============================================
// ลูกค้า / Customers
// ============================================
model Customer {
  id            String       @id @default(cuid())
  code          String       @unique // รหัสลูกค้า - UNIQUE with fiscal year in PostgreSQL
  name          String // ชื่อลูกค้า
  nameEn        String? // ชื่อภาษาอังกฤษ
  taxId         String? // เลขประจำตัวผู้เสียภาษี
  branchCode    String? // รหัสสาขา
  address       String? // ที่อยู่
  subDistrict   String? // แขวง/ตำบล
  district      String? // เขต/อำเภอ
  province      String? // จังหวัด
  postalCode    String? // รหัสไปรษณีย์
  phone         String? // โทรศัพท์
  fax           String? // โทรสาร
  email         String? // อีเมล
  website       String? // เว็บไซต์
  contactName   String? // ชื่อผู้ติดต่อ
  contactPhone  String? // โทรศัพท์ผู้ติดต่อ
  creditLimit   Int          @default(0) // วงเงินเครดิต (สตางค์)
  creditDays    Int          @default(30) // เครดิต (วัน)
  isActive      Boolean      @default(true)
  deletedAt     DateTime?
  deletedBy     String?
  notes         String? // หมายเหตุ
  externalRefId String?      @unique // สำหรับเชื่อมต่อระบบภายนอก (CRM/POS)
  metadata      Json? // ข้อมูลส่วนขยาย
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  invoices      Invoice[]
  receipts      Receipt[]
  creditNotes   CreditNote[]

  @@index([deletedAt])
}

// ============================================
// ผู้ขาย / Vendors
// ============================================
model Vendor {
  id               String            @id @default(cuid())
  code             String            @unique // รหัสผู้ขาย - UNIQUE with fiscal year in PostgreSQL
  name             String // ชื่อผู้ขาย
  nameEn           String? // ชื่อภาษาอังกฤษ
  taxId            String? // เลขประจำตัวผู้เสียภาษี
  branchCode       String? // รหัสสาขา
  address          String? // ที่อยู่
  subDistrict      String? // แขวง/ตำบล
  district         String? // เขต/อำเภอ
  province         String? // จังหวัด
  postalCode       String? // รหัสไปรษณีย์
  phone            String? // โทรศัพท์
  fax              String? // โทรสาร
  email            String? // อีเมล
  website          String? // เว็บไซต์
  contactName      String? // ชื่อผู้ติดต่อ
  contactPhone     String? // โทรศัพท์ผู้ติดต่อ
  bankName         String? // ชื่อธนาคาร
  bankAccount      String? // เลขที่บัญชี
  bankAccountName  String? // ชื่อบัญชี
  creditDays       Int               @default(30) // เครดิต (วัน)
  isActive         Boolean           @default(true)
  deletedAt        DateTime?
  deletedBy        String?
  notes            String? // หมายเหตุ
  externalRefId    String?           @unique // สำหรับเชื่อมต่อระบบภายนอก
  metadata         Json? // ข้อมูลส่วนขยาย
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  purchaseInvoices PurchaseInvoice[]
  payments         Payment[]
  debitNotes       DebitNote[]
  purchaseOrders   PurchaseOrder[]   @relation("POVendor")

  @@index([deletedAt])
}

// ============================================
// สินค้า/บริการ / Products & Services
// ============================================
model Product {
  id                   String                @id @default(cuid())
  code                 String                @unique // รหัสสินค้า - UNIQUE with fiscal year in PostgreSQL
  name                 String // ชื่อสินค้า
  nameEn               String? // ชื่อภาษาอังกฤษ
  description          String? // รายละเอียด
  category             String? // หมวดหมู่
  unit                 String                @default("ชิ้น") // หน่วย
  type                 ProductType           @default(PRODUCT) // ประเภท
  salePrice            Int                   @default(0) // ราคาขาย (สตางค์) - CHECK: >= 0
  costPrice            Int                   @default(0) // ราคาทุน (สตางค์) - CHECK: >= 0
  vatRate              Float                 @default(7) // อัตรา VAT (%)
  vatType              VatType               @default(EXCLUSIVE) // ประเภท VAT
  isInventory          Boolean               @default(false) // ติดตามสต็อก
  quantity             Float                 @default(0) // จำนวนคงเหลือ (หน่วย) - CHECK: >= 0
  minQuantity          Float                 @default(0) // จำนวนต่ำสุด (หน่วย) - CHECK: >= 0
  incomeType           String? // ประเภทรายได้ (สำหรับหัก ณ ที่จ่าย 50 ทวิ)
  costingMethod        CostingMethod         @default(WEIGHTED_AVERAGE)
  isActive             Boolean               @default(true)
  deletedAt            DateTime?
  deletedBy            String?
  notes                String? // หมายเหตุ
  metadata             Json? // ข้อมูลส่วนขยาย
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  invoiceLines         InvoiceLine[]
  purchaseLines        PurchaseInvoiceLine[]
  stockBalances        StockBalance[]
  stockMovements       StockMovement[]
  stockTransferLines   StockTransferLine[]
  stockTakeLines       StockTakeLine[]
  productCostHistories ProductCostHistory[]
  prRequestLines       PurchaseRequestLine[] @relation("PRLineProduct")
  poOrderLines         PurchaseOrderLine[] @relation("POLineProduct")

  @@index([deletedAt])
}

enum CostingMethod {
  FIFO
  WEIGHTED_AVERAGE
}

enum ProductType {
  PRODUCT // สินค้า
  SERVICE // บริการ
}

enum VatType {
  EXCLUSIVE // ยังไม่รวม VAT
  INCLUSIVE // รวม VAT แล้ว
  NONE // ไม่มี VAT
}

// B3. Enhanced VAT Types for Tax Reporting
enum VatRateType {
  STANDARD_7 // อัตรามาตรฐาน 7%
  ZERO_RATE // อัตราศูนย์ 0% (ส่งออก)
  EXEMPT // ยกเว้นภาษี
  NON_VAT // ไม่เข้าข่าย VAT
}

// ============================================
// ใบกำกับภาษี / Tax Invoice
// ============================================
model Invoice {
  id                 String              @id @default(cuid())
  invoiceNo          String              @unique // เลขที่ใบกำกับภาษี
  invoiceDate        DateTime // วันที่ออกใบกำกับภาษี
  dueDate            DateTime? // วันครบกำหนด - CHECK: dueDate >= invoiceDate
  customerId         String
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  type               InvoiceType         @default(TAX_INVOICE)
  reference          String? // เอกสารอ้างอิง
  poNumber           String? // เลขที่ใบสั่งซื้อ
  subtotal           Int                 @default(0) // มูลค่าก่อน VAT (สตางค์)
  vatRate            Float               @default(7) // อัตรา VAT (%)
  vatRateType        VatRateType         @default(STANDARD_7) // ประเภทอัตรา VAT
  vatAmount          Int                 @default(0) // ภาษีมูลค่าเพิ่ม (สตางค์)
  totalAmount        Int                 @default(0) // ยอดรวม (สตางค์)
  discountAmount     Int                 @default(0) // ส่วนลด (สตางค์) - CHECK: >= 0
  discountPercent    Float               @default(0) // ส่วนลด (%) - CHECK: 0-100
  withholdingRate    Float               @default(0) // อัตราภาษีหัก ณ ที่จ่าย (%) - CHECK: 0-100
  withholdingAmount  Int                 @default(0) // ภาษีหัก ณ ที่จ่าย (สตางค์)
  netAmount          Int                 @default(0) // ยอดสุทธิ (สตางค์)
  paidAmount         Int                 @default(0) // ยอดชำระแล้ว (สตางค์) - CHECK: >= 0 AND <= totalAmount
  status             InvoiceStatus       @default(DRAFT)
  notes              String? // หมายเหตุ
  internalNotes      String? // หมายเหตุภายใน
  terms              String? // เงื่อนไข
  sourceChannel      String? // ช่องทางที่มา (เช่น POS, WEB, API)
  metadata           Json? // ข้อมูลส่วนขยาย
  createdById        String?
  isActive           Boolean             @default(true)
  deletedAt          DateTime?
  deletedBy          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lines              InvoiceLine[]
  receiptAllocations ReceiptAllocation[]
  journalEntryId     String? // ID บันทึกบัญชี
  journalEntry       JournalEntry?       @relation("InvoiceJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  creditNotes        CreditNote[] // ใบลดหนี้ที่อ้างอิงใบกำกับภาษีนี้
  comments           InvoiceComment[]

  // Multi-currency fields
  currencyId    String?
  currency      Currency? @relation(fields: [currencyId], references: [id])
  exchangeRate  Float     @default(1) // อัตราแลกเปลี่ยน (THB per 1 unit of foreign currency)
  foreignAmount Int? // จำนวนเงินต่างประเทศ (สตางค์)

  @@index([customerId])
  @@index([journalEntryId])
  @@index([createdById])
  @@index([deletedAt])
  @@index([currencyId])
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineNo      Int // ลำดับ
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String // รายการ
  quantity    Float    @default(1) // จำนวน (หน่วย)
  unit        String   @default("ชิ้น") // หน่วย
  unitPrice   Int      @default(0) // ราคาต่อหน่วย (สตางค์)
  discount    Int      @default(0) // ส่วนลด (สตางค์)
  amount      Int      @default(0) // จำนวนเงิน (สตางค์)
  vatRate     Float    @default(7) // อัตรา VAT (%)
  vatAmount   Int      @default(0) // ภาษีมูลค่าเพิ่ม (สตางค์)
  notes       String? // หมายเหตุ
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  auditTrail  InvoiceLineItemAudit[]

  @@index([invoiceId])
  @@index([productId])
}

enum InvoiceType {
  TAX_INVOICE // ใบกำกับภาษี
  RECEIPT // ใบเสร็จรับเงิน
  DELIVERY_NOTE // ใบส่งของ
  CREDIT_NOTE // ใบลดหนี้
  DEBIT_NOTE // ใบเพิ่มหนี้
}

enum InvoiceStatus {
  DRAFT // ร่าง
  ISSUED // ออกแล้ว
  PARTIAL // รับชำระแล้วบางส่วน
  PAID // รับชำระเต็มจำนวน
  CANCELLED // ยกเลิก
}

// ============================================
// ใบเสร็จรับเงิน / Receipt
// ============================================
model Receipt {
  id             String              @id @default(cuid())
  receiptNo      String              @unique // เลขที่ใบเสร็จ - UNIQUE with fiscal year in PostgreSQL
  receiptDate    DateTime // วันที่รับเงิน
  customerId     String
  customer       Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  paymentMethod  PaymentMethod       @default(CASH)
  bankAccountId  String? // ID บัญชีธนาคาร
  bankAccount    BankAccount?        @relation(fields: [bankAccountId], references: [id])
  chequeNo       String? // เลขที่เช็ค
  chequeDate     DateTime? // วันที่เช็ค
  amount         Int                 @default(0) // จำนวนเงินรับโดยสิ้นเชิง (สตางค์) - CHECK: >= 0
  whtAmount      Int                 @default(0) // ภาษีหัก ณ ที่จ่ายรวม (สตางค์) - CHECK: >= 0
  unallocated    Int                 @default(0) // ยอดที่ยังไม่ได้จัดจ่าย (สตางค์) - CHECK: >= 0
  notes          String? // หมายเหตุ
  status         ReceiptStatus       @default(DRAFT)
  journalEntryId String? // ID บันทึกบัญชี
  idempotencyKey String?             @unique // ✅ FIXED: Prevent duplicate receipts
  isActive       Boolean             @default(true)
  deletedAt      DateTime?
  deletedBy      String?
  journalEntry   JournalEntry?       @relation("ReceiptJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  allocations    ReceiptAllocation[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Multi-currency fields
  currencyId    String?
  currency      Currency? @relation(fields: [currencyId], references: [id])
  exchangeRate  Float     @default(1)
  foreignAmount Int?

  @@index([customerId])
  @@index([bankAccountId])
  @@index([journalEntryId])
  @@index([deletedAt])
  @@index([currencyId])
}

model ReceiptAllocation {
  id        String   @id @default(cuid())
  receiptId String
  invoiceId String
  amount    Int // จำนวนเงินที่จ่าย (สตางค์)
  whtRate   Float    @default(0) // อัตราหัก ณ ที่จ่าย (%)
  whtAmount Int      @default(0) // ภาษีหัก ณ ที่จ่าย (สตางค์)
  receipt   Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  createdAt DateTime @default(now())

  @@index([receiptId])
  @@index([invoiceId])
}

enum PaymentMethod {
  CASH // เงินสด
  CHEQUE // เช็ค
  TRANSFER // โอนเงิน
  CREDIT // บัตรเครดิต
  OTHER // อื่นๆ
}

enum ReceiptStatus {
  DRAFT // ร่าง
  POSTED // ลงบัญชีแล้ว
  CANCELLED // ยกเลิก
}

// ============================================
// ใบลดหนี้ / Credit Note
// ============================================
model CreditNote {
  id             String           @id @default(cuid())
  creditNoteNo   String           @unique // เลขที่ใบลดหนี้
  creditNoteDate DateTime // วันที่ออก
  customerId     String
  customer       Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  invoiceId      String? // อ้างอิงใบกำกับภาษี
  invoice        Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  reason         String? // เหตุผล
  subtotal       Int              @default(0) // มูลค่าก่อน VAT (สตางค์)
  vatRate        Float            @default(7) // อัตรา VAT (%)
  vatAmount      Int              @default(0) // ภาษีมูลค่าเพิ่ม (สตางค์)
  totalAmount    Int              @default(0) // ยอดรวม (สตางค์)
  status         CreditNoteStatus @default(ISSUED)
  notes          String? // หมายเหตุ
  isActive       Boolean          @default(true)
  deletedAt      DateTime?
  deletedBy      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  journalEntryId String? // ID บันทึกบัญชี
  journalEntry   JournalEntry?    @relation("CreditNoteJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)

  @@index([customerId])
  @@index([invoiceId])
  @@index([journalEntryId])
  @@index([deletedAt])
}

enum CreditNoteStatus {
  ISSUED // ออกแล้ว
  CANCELLED // ยกเลิก
}

// ============================================
// ใบเพิ่มหนี้ / Debit Note
// ============================================
model DebitNote {
  id              String           @id @default(cuid())
  debitNoteNo     String           @unique // เลขที่ใบเพิ่มหนี้
  debitNoteDate   DateTime // วันที่ออก
  vendorId        String
  vendor          Vendor           @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  invoiceId       String? // อ้างอิงใบซื้อ
  purchaseInvoice PurchaseInvoice? @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  reason          String? // เหตุผล
  subtotal        Int              @default(0) // มูลค่าก่อน VAT (สตางค์)
  vatRate         Float            @default(7) // อัตรา VAT (%)
  vatAmount       Int              @default(0) // ภาษีมูลค่าเพิ่ม (สตางค์)
  totalAmount     Int              @default(0) // ยอดรวม (สตางค์)
  status          DebitNoteStatus  @default(ISSUED)
  notes           String? // หมายเหตุ
  isActive        Boolean          @default(true)
  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  journalEntryId  String? // ID บันทึกบัญชี
  journalEntry    JournalEntry?    @relation("DebitNoteJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)

  @@index([vendorId])
  @@index([invoiceId])
  @@index([journalEntryId])
  @@index([deletedAt])
}

enum DebitNoteStatus {
  ISSUED // ออกแล้ว
  CANCELLED // ยกเลิก
}

// ============================================
// ใบซื้อ / Purchase Invoice
// ============================================
model PurchaseInvoice {
  id                 String                @id @default(cuid())
  invoiceNo          String                @unique // เลขที่ใบซื้อ
  vendorInvoiceNo    String? // เลขที่ใบกำกับภาษีของผู้ขาย
  invoiceDate        DateTime // วันที่ใบกำกับภาษี
  dueDate            DateTime? // วันครบกำหนด
  vendorId           String
  vendor             Vendor                @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  type               InvoiceType           @default(TAX_INVOICE)
  reference          String? // เอกสารอ้างอิง
  poNumber           String? // เลขที่ใบสั่งซื้อ
  subtotal           Int                   @default(0) // มูลค่าก่อน VAT (สตางค์)
  vatRate            Float                 @default(7) // อัตรา VAT (%)
  vatRateType        VatRateType           @default(STANDARD_7) // ประเภทอัตรา VAT
  vatAmount          Int                   @default(0) // ภาษีมูลค่าเพิ่ม (สตางค์)
  totalAmount        Int                   @default(0) // ยอดรวม (สตางค์)
  discountAmount     Int                   @default(0) // ส่วนลด (สตางค์)
  withholdingRate    Float                 @default(0) // อัตราภาษีหัก ณ ที่จ่าย (%)
  withholdingAmount  Int                   @default(0) // ภาษีหัก ณ ที่จ่าย (สตางค์)
  netAmount          Int                   @default(0) // ยอดสุทธิ (สตางค์)
  paidAmount         Int                   @default(0) // ยอดชำระแล้ว (สตางค์)
  status             InvoiceStatus         @default(DRAFT)
  notes              String? // หมายเหตุ
  internalNotes      String? // หมายเหตุภายใน
  sourceChannel      String? // ช่องทางที่มา (เช่น POS, WEB, API)
  metadata           Json? // ข้อมูลส่วนขยาย
  createdById        String?
  isActive           Boolean               @default(true)
  deletedAt          DateTime?
  deletedBy          String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  lines              PurchaseInvoiceLine[]
  paymentAllocations PaymentAllocation[]   @relation("PaymentAllocations")
  journalEntryId     String? // ID บันทึกบัญชี
  journalEntry       JournalEntry?         @relation("PurchaseInvoiceJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  debitNotes         DebitNote[] // ใบเพิ่มหนี้ที่อ้างอิงใบซื้อนี้
  purchaseOrders     PurchaseOrder[]       @relation("POInvoice") // POs linked to this invoice

  @@index([vendorId])
  @@index([journalEntryId])
  @@index([createdById])
  @@index([deletedAt])
}

model PurchaseInvoiceLine {
  id          String          @id @default(cuid())
  purchaseId  String
  purchase    PurchaseInvoice @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  lineNo      Int // ลำดับ
  productId   String?
  product     Product?        @relation(fields: [productId], references: [id])
  description String // รายการ
  quantity    Float           @default(1) // จำนวน (หน่วย)
  unit        String          @default("ชิ้น") // หน่วย
  unitPrice   Int             @default(0) // ราคาต่อหน่วย (สตางค์)
  discount    Int             @default(0) // ส่วนลด (สตางค์)
  amount      Int             @default(0) // จำนวนเงิน (สตางค์)
  vatRate     Float           @default(7) // อัตรา VAT (%)
  vatAmount   Int             @default(0) // ภาษีมูลค่าเพิ่ม (สตางค์)
  notes       String? // หมายเหตุ
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([purchaseId])
}

// ============================================
// ใบจ่ายเงิน / Payment (AP Payments)
// ============================================
model Payment {
  id             String              @id @default(cuid())
  paymentNo      String              @unique // เลขที่ใบจ่ายเงิน - UNIQUE with fiscal year in PostgreSQL
  paymentDate    DateTime // วันที่จ่ายเงิน
  vendorId       String
  vendor         Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  paymentMethod  PaymentMethod       @default(CASH)
  bankAccountId  String?
  bankAccount    BankAccount?        @relation("PaymentBankAccount", fields: [bankAccountId], references: [id])
  chequeNo       String? // เลขที่เช็ค
  chequeDate     DateTime? // วันที่เช็ค
  amount         Int                 @default(0) // จำนวนเงินรวม (สตางค์)
  whtAmount      Int                 @default(0) // ภาษีหัก ณ ที่จ่ายรวม (สตางค์)
  unallocated    Int                 @default(0) // ยอดคงเหลือ (สตางค์)
  notes          String? // หมายเหตุ
  status         PaymentStatus       @default(DRAFT)
  createdById    String?
  idempotencyKey String?             @unique // ✅ FIXED: Prevent duplicate payments
  isActive       Boolean             @default(true)
  deletedAt      DateTime?
  deletedBy      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  journalEntryId String? // ID บันทึกบัญชี
  journalEntry   JournalEntry?       @relation("PaymentJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  allocations    PaymentAllocation[]
  cheques        Cheque[]            @relation("PaymentCheque")

  // Multi-currency fields
  currencyId    String?
  currency      Currency? @relation(fields: [currencyId], references: [id])
  exchangeRate  Float     @default(1)
  foreignAmount Int?

  @@index([vendorId])
  @@index([bankAccountId])
  @@index([journalEntryId])
  @@index([deletedAt])
  @@index([currencyId])
}

model PaymentAllocation {
  id        String          @id @default(cuid())
  paymentId String
  payment   Payment         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId String
  invoice   PurchaseInvoice @relation("PaymentAllocations", fields: [invoiceId], references: [id], onDelete: Restrict)
  amount    Int // จำนวนเงินที่จ่าย (สตางค์)
  whtRate   Float           @default(0) // อัตราหัก ณ ที่จ่าย (%)
  whtAmount Int             @default(0) // ภาษีหัก ณ ที่จ่าย (สตางค์)
  notes     String?
  createdAt DateTime        @default(now())

  @@index([paymentId])
  @@index([invoiceId])
}

enum PaymentStatus {
  DRAFT // ร่าง
  POSTED // ลงบัญชีแล้ว
  CANCELLED // ยกเลิก
}

// ============================================
// ภาษีมูลค่าเพิ่ม / VAT Records
// ============================================
model VatRecord {
  id            String          @id @default(cuid())
  type          VatRecordType // ประเภท
  documentNo    String // เลขที่เอกสาร
  documentDate  DateTime // วันที่
  documentType  String? // ประเภทเอกสาร
  referenceId   String? // ID เอกสารอ้างอิง
  customerId    String? // ID ลูกค้า
  customerName  String? // ชื่อลูกค้า
  customerTaxId String? // เลขประจำตัวผู้เสียภาษีลูกค้า
  vendorId      String? // ID ผู้ขาย
  vendorName    String? // ชื่อผู้ขาย
  vendorTaxId   String? // เลขประจำตัวผู้เสียภาษีผู้ขาย
  description   String? // รายการ
  subtotal      Int             @default(0) // มูลค่าก่อน VAT (สตางค์)
  vatRate       Float           @default(7) // อัตรา VAT (%)
  vatAmount     Int             @default(0) // ภาษีมูลค่าเพิ่ม (สตางค์)
  totalAmount   Int             @default(0) // ยอดรวม (สตางค์)
  taxMonth      Int // เดือนที่ยื่นภาษี
  taxYear       Int // ปีที่ยื่นภาษี
  reportStatus  VatReportStatus @default(PENDING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([type, taxMonth, taxYear])
}

enum VatRecordType {
  INPUT // ภาษีซื้อ
  OUTPUT // ภาษีขาย
}

enum VatReportStatus {
  PENDING // รอรายงาน
  REPORTED // รายงานแล้ว
}

// ============================================
// ภาษีหัก ณ ที่จ่าย / Withholding Tax
// ============================================
model WithholdingTax {
  id           String          @id @default(cuid())
  type         WhtType // ประเภท
  documentNo   String // เลขที่หนังสือรับรอง
  documentDate DateTime // วันที่
  documentType String? // ประเภทเอกสาร
  referenceId  String? // ID เอกสารอ้างอิง
  payeeId      String? // ID ผู้ถูกหักภาษี
  payeeName    String // ชื่อผู้ถูกหักภาษี
  payeeTaxId   String? // เลขประจำตัวผู้เสียภาษี
  payeeAddress String? // ที่อยู่ผู้ถูกหักภาษี
  description  String? // รายการ
  incomeType   String? // ประเภทเงินได้
  incomeAmount Int             @default(0) // จำนวนเงินที่จ่าย (สตางค์)
  whtRate      Float           @default(3) // อัตราภาษีหัก ณ ที่จ่าย (%)
  whtAmount    Int             @default(0) // ภาษีที่หัก (สตางค์)
  taxMonth     Int // เดือนที่ยื่นภาษี
  taxYear      Int // ปีที่ยื่นภาษี
  reportStatus WhtReportStatus @default(PENDING)
  notes        String? // หมายเหตุ
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([type, taxMonth, taxYear])
}

enum WhtType {
  PND3 // ภงด.3 (เงินเดือน/ค่าจ้าง)
  PND53 // ภงด.53 (ค่าบริการ/ค่าเช่า)
}

enum WhtReportStatus {
  PENDING // รอรายงาน
  REPORTED // รายงานแล้ว
}

// ============================================
// งบการเงิน / Financial Reports
// ============================================
model FinancialReport {
  id        String     @id @default(cuid())
  type      ReportType // ประเภทรายงาน
  name      String // ชื่อรายงาน
  startDate DateTime // วันที่เริ่ม
  endDate   DateTime // วันที่สิ้นสุด
  data      String // ข้อมูล JSON
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum ReportType {
  TRIAL_BALANCE // งบทดลอง
  BALANCE_SHEET // งบดุล
  INCOME_STATEMENT // งบกำไรขาดทุน
  GENERAL_LEDGER // สมุดบัญชีแยกประเภท
  AGING_AR // รายงานลูกหนี้ตามอายุหนี้
  AGING_AP // รายงานเจ้าหนี้ตามอายุหนี้
  VAT_REPORT // รายงานภาษีมูลค่าเพิ่ม
  WHT_REPORT // รายงานภาษีหัก ณ ที่จ่าย
}

// ============================================
// ผู้ใช้งาน / Users
// ============================================
model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String // รหัสผ่าน (hashed)
  name           String?
  role           UserRole        @default(USER)
  isActive       Boolean         @default(true)
  lastLoginAt    DateTime?
  // MFA fields
  mfaSecret      String? // Encrypted TOTP secret
  mfaEnabled     Boolean         @default(false)
  mfaVerifiedAt  DateTime? // When MFA was first verified
  // Session management
  maxSessions    Int             @default(3) // Maximum concurrent sessions
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  pettyCashFunds PettyCashFund[]
  dataImports    DataImport[]    @relation("DataImportUser")
  activityLogs   ActivityLog[]
  auditLogs      AuditLog[]      @relation("AuditUser")
  preferences    UserPreference?

  // PR/PO Relations
  managedDepartments Department[]   @relation("DeptManager")
  createdDepartments  Department[]   @relation("DeptCreator")
  createdDeptBudgets  DepartmentBudget[] @relation("DeptBudgetCreator")
  createdPRs          PurchaseRequest[] @relation("PRCreator")
  updatedPRs          PurchaseRequest[] @relation("PRUpdater")
  approvedPRs         PurchaseRequest[] @relation("PRApprover")
  createdPOs          PurchaseOrder[]   @relation("POCreator")
  updatedPOs          PurchaseOrder[]   @relation("POUpdater")
}

enum UserRole {
  ADMIN // ผู้ดูแลระบบ
  ACCOUNTANT // นักบัญชี
  USER // ผู้ใช้ทั่วไป
  VIEWER // ผู้ดูเท่านั้น
}

// ============================================
// เลขที่เอกสาร / Document Numbering
// ============================================
model DocumentNumber {
  id           String   @id @default(cuid())
  type         String   @unique // ประเภทเอกสาร
  prefix       String // คำนำหน้า
  currentNo    Int      @default(0) // เลขที่ปัจจุบัน
  format       String   @default("{prefix}{yyyy}{mm}-{0000}") // รูปแบบ
  resetMonthly Boolean  @default(true) // เริ่มใหม่ทุกเดือน
  resetYearly  Boolean  @default(false) // เริ่มใหม่ทุกปี
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// การจับคู่รายการ / Reconciliation
// ============================================
model Reconciliation {
  id          String               @id @default(cuid())
  type        ReconciliationType // ประเภท
  date        DateTime // วันที่
  reference   String? // เอกสารอ้างอิง
  debitId     String? // ID รายการเดบิต
  debitType   String? // ประเภทรายการเดบิต
  creditId    String? // ID รายการเครดิต
  creditType  String? // ประเภทรายการเครดิต
  amount      Int                  @default(0) // จำนวนเงิน (สตางค์)
  status      ReconciliationStatus @default(PENDING)
  matchedAt   DateTime? // วันที่จับคู่
  matchedById String? // ผู้จับคู่
  notes       String? // หมายเหตุ
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

enum ReconciliationType {
  BANK // กระทบยอดธนาคาร
  AR_PAYMENT // จับคู่รับชำระ
  AP_PAYMENT // จับคู่จ่ายชำระ
}

enum ReconciliationStatus {
  PENDING // รอจับคู่
  MATCHED // จับคู่แล้ว
  UNMATCHED // ไม่ตรงกัน
}

// ============================================
// การเชื่อมต่อระบบภายนอก (Headless API Access)
// ============================================
model ApiToken {
  id         String    @id @default(cuid())
  name       String // e.g., "POS-BKK-01" or "HR-System"
  tokenHash  String    @unique
  scopes     String // e.g., "invoice:write, stock:read"
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  isActive   Boolean   @default(true)
}

// ============================================
// คลังสินค้าและสินค้าคงคลัง (Inventory & Stock)
// ============================================
model InventoryConfig {
  id                    String   @id @default("default") // Singleton
  stockMovementTrigger  String   @default("ON_ISSUE") // "ON_ISSUE" | "ON_CREATE"
  enableMultiCurrency   Boolean  @default(false)
  defaultCostingMethod  String   @default("WEIGHTED_AVERAGE") // "FIFO" | "WEIGHTED_AVERAGE"
  defaultWarehouseId    String?
  autoCreateCOGSJournal Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}

model Warehouse {
  id             String          @id @default(cuid())
  code           String          @unique // รหัสคลัง
  name           String // ชื่อคลัง
  type           WarehouseType   @default(MAIN)
  location       String? // ที่ตั้ง
  isActive       Boolean         @default(true)
  notes          String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  zones          WarehouseZone[]
  balances       StockBalance[]
  stockMovements StockMovement[]
  stockTakes     StockTake[]
}

model WarehouseZone {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  code        String // รหัสโซน e.g., A1, B2
  name        String // ชื่อโซน
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, code])
}

model StockBalance {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Float     @default(0) // จำนวนคงเหลือ (หน่วย)
  unitCost    Int       @default(0) // ต้นทุนต่อหน่วย (สตางค์)
  totalCost   Int       @default(0) // ต้นทุนรวม (สตางค์)
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model StockMovement {
  id            String       @id @default(cuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  warehouseId   String
  warehouse     Warehouse    @relation(fields: [warehouseId], references: [id])
  type          MovementType // ประเภทการเคลื่อนไหว
  quantity      Float // จำนวน (บวก/ลบ) (หน่วย)
  unitCost      Int // ต้นทุนต่อหน่วย (สตางค์)
  totalCost     Int // ต้นทุนรวม (สตางค์)
  date          DateTime
  referenceId   String? // อ้างอิงเอกสาร (Invoice ID, Purchase ID, Transfer ID)
  referenceNo   String? // เลขที่เอกสารอ้างอิง
  sourceChannel String? // ช่องทางที่มา
  notes         String?
  createdById   String?
  createdAt     DateTime     @default(now())
  // Multi-currency support
  currency      String?      @default("THB")
  exchangeRate  Float?       @default(1.0)
  foreignCost   Int?

  @@index([productId])
  @@index([warehouseId])
  @@index([referenceId])
}

model StockTransfer {
  id              String              @id @default(cuid())
  transferNo      String              @unique
  date            DateTime
  fromWarehouseId String
  toWarehouseId   String
  status          TransferStatus      @default(DRAFT)
  requestedById   String?
  approvedById    String?
  notes           String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  lines           StockTransferLine[]

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model StockTransferLine {
  id         String        @id @default(cuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  quantity   Float // จำนวน (หน่วย)
  notes      String?
}

model StockTake {
  id              String          @id @default(cuid())
  stockTakeNumber String          @unique
  warehouseId     String
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id])
  status          StockTakeStatus @default(DRAFT)
  takeDate        DateTime
  createdBy       String
  createdByName   String?
  approvedBy      String?
  approvedByName  String?
  approvedAt      DateTime?
  lines           StockTakeLine[]
  journalEntryId  String?         @unique
  journalEntry    JournalEntry?   @relation("StockTakeJournal", fields: [journalEntryId], references: [id])
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([warehouseId])
  @@index([status])
  @@index([takeDate])
}

model StockTakeLine {
  id            String    @id @default(cuid())
  stockTakeId   String
  stockTake     StockTake @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  expectedQty   Float // จำนวนคาดหมาย (หน่วย)
  actualQty     Float // จำนวนตรวจนับจริง (หน่วย)
  varianceQty   Float // ผลต่างจำนวน (หน่วย)
  varianceValue Int // ผลต่างมูลค่า (สตางค์)
  costPerUnit   Int // ต้นทุนต่อหน่วย (สตางค์)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([stockTakeId])
  @@index([productId])
}

model ProductCostHistory {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  date        DateTime
  oldUnitCost Int // ต้นทุนเดิม (สตางค์)
  newUnitCost Int // ต้นทุนใหม่ (สตางค์)
  reason      String?
  referenceId String?
  createdAt   DateTime @default(now())
}

enum WarehouseType {
  MAIN
  BRANCH
  VAN
}

enum MovementType {
  RECEIVE
  ISSUE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUST
  RETURN
  INITIAL
}

enum TransferStatus {
  DRAFT
  REQUESTED
  APPROVED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum StockTakeStatus {
  DRAFT
  IN_PROGRESS
  PENDING_APPROVAL
  APPROVED
  POSTED
  CANCELLED
}

// ============================================
// ทะเบียนทรัพย์สิน และ ค่าเสื่อมราคา (Fixed Assets)
// ============================================
model Asset {
  id                  String                 @id @default(cuid())
  code                String                 @unique
  name                String
  purchaseDate        DateTime
  purchaseCost        Int // มูลค่าซื้อ (สตางค์)
  salvageValue        Int                    @default(100) // ค่าซาก 1 บาท (สตางค์)
  usefulLifeYears     Int
  depreciationRate    Float
  glAccountId         String // บัญชีสินทรัพย์
  accumDepAccountId   String // บัญชีค่าเสื่อมราคาสะสม
  depExpenseAccountId String // บัญชีค่าเสื่อมราคา
  isActive            Boolean                @default(true)
  deletedAt           DateTime?
  deletedBy           String?
  metadata            Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  schedules           DepreciationSchedule[]

  @@index([glAccountId])
  @@index([accumDepAccountId])
  @@index([depExpenseAccountId])
  @@index([deletedAt])
}

model DepreciationSchedule {
  id             String   @id @default(cuid())
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id])
  date           DateTime // สิ้นเดือน
  amount         Int // ค่าเสื่อมราคาประจำงวด (สตางค์)
  accumulated    Int // ค่าเสื่อมราคาสะสม (สตางค์)
  netBookValue   Int // มูลค่าตามบัญชี (สตางค์)
  journalEntryId String? // เลขที่บันทึกบัญชีที่ Post ไป GL
  posted         Boolean  @default(false)
  createdAt      DateTime @default(now())
}

// ============================================
// ทะเบียนคุมเช็ค และ ธนาคาร (Banking & Cheques)
// ============================================
model BankAccount {
  id              String               @id @default(cuid())
  code            String               @unique
  bankName        String
  branchName      String
  accountNumber   String
  accountName     String
  glAccountId     String
  isActive        Boolean              @default(true)
  metadata        Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  cheques         Cheque[]
  receipts        Receipt[]
  payments        Payment[]            @relation("PaymentBankAccount")
  reconciliations BankReconciliation[]
}

model Cheque {
  id               String              @id @default(cuid())
  chequeNo         String              @unique
  type             ChequeType // RECEIVE, PAY
  bankAccountId    String
  bankAccount      BankAccount         @relation(fields: [bankAccountId], references: [id])
  dueDate          DateTime
  amount           Int // จำนวนเงิน (สตางค์)
  payeeName        String?
  status           ChequeStatus // ON_HAND, DEPOSITED, CLEARED, BOUNCED, CANCELLED
  documentRef      String? // Links to Receipt / Payment
  clearedDate      DateTime?
  journalEntryId   String? // ID บันทึกบัญชีเมื่อเช็คผ่าน
  journalEntry     JournalEntry?       @relation("ChequeJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  isReconciled     Boolean             @default(false)
  reconciliationId String?
  reconciliation   BankReconciliation? @relation(fields: [reconciliationId], references: [id])
  paymentId        String?
  payment          Payment?            @relation("PaymentCheque", fields: [paymentId], references: [id])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([bankAccountId])
  @@index([paymentId])
  @@index([journalEntryId])
}

enum ChequeType {
  RECEIVE
  PAY
}

enum ChequeStatus {
  ON_HAND
  DEPOSITED
  CLEARED
  BOUNCED
  CANCELLED
}

// Bank Reconciliation
model BankReconciliation {
  id               String               @id @default(cuid())
  bankAccountId    String
  bankAccount      BankAccount          @relation(fields: [bankAccountId], references: [id])
  statementDate    DateTime // วันที่รายการเดินบัญชี
  statementBalance Int                  @default(0) // ยอดเงินตามรายการเดินบัญชี (สตางค์)
  bookBalance      Int                  @default(0) // ยอดเงินตามสมุดบัญชี (สตางค์)
  difference       Int                  @default(0) // ผลต่าง statement - book (สตางค์)
  status           ReconciliationStatus @default(PENDING)
  reconciledAt     DateTime?
  reconciledById   String?
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  cheques          Cheque[]
}

// ============================================
// เงินสดย่อย (Petty Cash)
// ============================================
model PettyCashFund {
  id             String             @id @default(cuid())
  code           String             @unique
  name           String
  custodianId    String
  custodian      User               @relation(fields: [custodianId], references: [id])
  glAccountId    String
  maxAmount      Int // วงเงินสูงสุด (สตางค์)
  currentBalance Int // ยอดคงเหลือปัจจุบัน (สตางค์)
  isActive       Boolean            @default(true)
  metadata       Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  vouchers       PettyCashVoucher[]

  @@index([custodianId])
  @@index([glAccountId])
}

model PettyCashVoucher {
  id                 String        @id @default(cuid())
  voucherNo          String        @unique
  fundId             String
  fund               PettyCashFund @relation(fields: [fundId], references: [id])
  date               DateTime
  amount             Int // จำนวนเงิน (สตางค์)
  payee              String
  description        String
  glExpenseAccountId String
  journalEntryId     String?
  journalEntry       JournalEntry? @relation("PettyCashVoucherJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  isReimbursed       Boolean       @default(false)
  createdAt          DateTime      @default(now())

  @@index([fundId])
  @@index([journalEntryId])
}

// ============================================
// ระบบเงินเดือน (Payroll)
// ============================================
model Employee {
  id               String    @id @default(cuid())
  employeeCode     String    @unique
  externalRefId    String?   @unique // Link to future full-HR System
  firstName        String
  lastName         String
  idCardNumber     String?
  hireDate         DateTime
  baseSalary       Int // เงินเดือนพื้นฐาน (สตางค์)
  position         String?
  department       String?
  socialSecurityNo String?
  taxId            String?
  bankAccountNo    String?
  bankName         String?
  isActive         Boolean   @default(true)
  deletedAt        DateTime?
  deletedBy        String?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  payrolls         Payroll[]

  @@index([deletedAt])
}

model PayrollRun {
  id              String        @id @default(cuid())
  runNo           String        @unique // PR202603-001
  periodMonth     Int
  periodYear      Int
  paymentDate     DateTime
  totalBaseSalary Int // รวมเงินเดือนพื้นฐาน (สตางค์)
  totalAdditions  Int // รวมรายได้อื่น (สตางค์)
  totalDeductions Int // รวมรายหัก (สตางค์)
  totalSsc        Int // รวมประกันสังคม (สตางค์)
  totalTax        Int // รวมภาษี (สตางค์)
  totalNetPay     Int // รวมจ่ายสุทธิ (สตางค์)
  status          PayrollStatus // DRAFT, APPROVED, PAID
  journalEntryId  String? // Linked to GL Posting
  journalEntry    JournalEntry? @relation("PayrollRunJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payrolls        Payroll[]

  @@index([journalEntryId])
}

model Payroll {
  id             String     @id @default(cuid())
  payrollRunId   String
  payrollRun     PayrollRun @relation(fields: [payrollRunId], references: [id])
  employeeId     String
  employee       Employee   @relation(fields: [employeeId], references: [id])
  baseSalary     Int // เงินเดือนพื้นฐาน (สตางค์)
  additions      Int // OT, Bonus (สตางค์)
  deductions     Int // Leave without pay (สตางค์)
  socialSecurity Int // ประกันสังคม (สตางค์)
  withholdingTax Int // ภาษี ภงด.1 (สตางค์)
  netPay         Int // จ่ายสุทธิ (สตางค์)
  payslipUrl     String?
  createdAt      DateTime   @default(now())
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

// ============================================
// ประวัติการนำเข้าข้อมูล (Data Import History)
// ============================================
model DataImport {
  id           String       @id @default(cuid())
  dataType     String // customers, vendors, products, accounts
  fileName     String
  fileType     String // csv, json
  totalRecords Int
  createdCount Int
  updatedCount Int
  errorCount   Int
  status       ImportStatus @default(COMPLETED)
  errorMessage String?
  importedById String?
  importedBy   User?        @relation("DataImportUser", fields: [importedById], references: [id])
  errorDetails Json? // Detailed error information
  createdAt    DateTime     @default(now())
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// บันทึกกิจกรรม (Activity Log)
// ============================================
model ActivityLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  action       String // LOGIN, LOGOUT, CREATE, UPDATE, DELETE, POST, VIEW, EXPORT, etc.
  module       String // invoices, payments, inventory, banking, assets, payroll, petty-cash, etc.
  recordId     String? // ID of affected record
  details      Json? // Additional context (JSON data)
  ipAddress    String?
  status       String // success, failed
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
  @@index([status])
}

// ============================================
// B1. งวดบัญชี / Accounting Periods
// ============================================
model AccountingPeriod {
  id         String                 @id @default(cuid())
  year       Int
  month      Int // 1-12
  status     AccountingPeriodStatus @default(OPEN)
  closedBy   String?
  closedAt   DateTime?
  reopenedBy String?
  reopenedAt DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@unique([year, month])
  @@index([status])
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

// ============================================
// B2. สกุลเงิน / Multi-Currency Support
// ============================================
model Currency {
  id            String         @id @default(cuid())
  code          String         @unique // THB, USD, EUR
  name          String
  nameTh        String? // ชื่อภาษาไทย
  symbol        String
  isBase        Boolean        @default(false) // THB is base
  decimalPlaces Int            @default(2)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  exchangeRates ExchangeRate[]
  invoices      Invoice[]
  payments      Payment[]
  receipts      Receipt[]
}

model ExchangeRate {
  id           String             @id @default(cuid())
  currencyId   String?
  currency     Currency?          @relation(fields: [currencyId], references: [id])
  fromCurrency String
  toCurrency   String
  rate         Float
  date         DateTime
  source       ExchangeRateSource @default(MANUAL)
  sourceRef    String? // API reference or manual entry note
  createdBy    String?
  createdAt    DateTime           @default(now())

  @@index([fromCurrency, toCurrency, date])
  @@index([date])
  @@index([currencyId])
}

enum ExchangeRateSource {
  MANUAL
  API
  SYSTEM
}

// Realized/Unrealized Gain/Loss tracking
model CurrencyGainLoss {
  id             String       @id @default(cuid())
  type           GainLossType // REALIZED or UNREALIZED
  documentType   String // Invoice, Payment, etc.
  documentId     String
  currencyCode   String
  originalRate   Float
  currentRate    Float
  amount         Int // Amount in foreign currency (satang)
  gainLossAmount Int // Gain/loss in THB (satang)
  date           DateTime
  isPosted       Boolean      @default(false)
  journalEntryId String?
  createdAt      DateTime     @default(now())

  @@index([type, date])
  @@index([documentType, documentId])
}

enum GainLossType {
  REALIZED
  UNREALIZED
}

// ============================================
// B3. แบบฟอร์มภาษี / Tax Forms
// ============================================
model TaxForm {
  id          String        @id @default(cuid())
  formType    TaxFormType // PND3, PND53, PP30
  month       Int // 1-12
  year        Int
  status      TaxFormStatus @default(DRAFT)
  totalAmount Int           @default(0) // มูลค่ารวม (สตางค์)
  totalTax    Int           @default(0) // ภาษีรวม (สตางค์)
  submittedAt DateTime?
  submittedBy String?
  filingDate  DateTime? // วันที่ยื่น
  receiptNo   String? // เลขที่ใบเสร็จรับเงิน
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lines       TaxFormLine[]
}

model TaxFormLine {
  id           String   @id @default(cuid())
  taxFormId    String
  taxForm      TaxForm  @relation(fields: [taxFormId], references: [id], onDelete: Cascade)
  lineNo       Int
  payeeId      String? // Customer/Vendor ID
  payeeName    String // ชื่อผู้ถูกหักภาษี
  payeeTaxId   String? // เลขประจำตัวผู้เสียภาษี
  payeeAddress String? // ที่อยู่
  description  String // รายการ
  incomeType   String // ประเภทเงินได้
  incomeAmount Int // จำนวนเงินที่จ่าย (สตางค์)
  taxRate      Float // อัตราภาษี (%)
  taxAmount    Int // ภาษีที่หัก (สตางค์)
  documentRef  String? // อ้างอิงเอกสาร
  createdAt    DateTime @default(now())

  @@index([taxFormId])
}

enum TaxFormType {
  PND3 // ภงด.3 - เงินเดือน/ค่าจ้าง/ค่านายหน้า/ค่าแห่งกำไร
  PND53 // ภงด.53 - ค่าบริการ/ค่าเช่า/ค่าส่งออก
  PP30 // ภ.พ.30 - ภาษีมูลค่าเพิ่ม
}

enum TaxFormStatus {
  DRAFT
  SUBMITTED
  FILED
}

// ============================================
// B4. งบประมาณ / Budgeting
// ============================================
model Budget {
  id        String         @id @default(cuid())
  year      Int
  accountId String
  account   ChartOfAccount @relation(fields: [accountId], references: [id])
  amount    Int // งบประมาณ (สตางค์)
  actual    Int            @default(0) // ใช้จริง (สตางค์)
  variance  Int            @default(0) // ผลต่าง (สตางค์)
  alertAt   Float          @default(80) // แจ้งเตือนเมื่อถึง %
  isAlerted Boolean        @default(false)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  alerts    BudgetAlert[]

  @@unique([year, accountId])
  @@index([year])
}

model BudgetAlert {
  id             String    @id @default(cuid())
  budgetId       String
  budget         Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  alertType      String // OVER_BUDGET, APPROACHING_LIMIT
  message        String
  triggeredAt    DateTime  @default(now())
  acknowledged   Boolean   @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?
}

// ============================================
// B5. บริษัทในเครือ / Inter-Company Transactions
// ============================================
model Entity {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  nameEn    String?
  taxId     String?
  isPrimary Boolean  @default(false) // บริษัทหลัก
  isActive  Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Inter-company relationships
  fromTransactions InterCompanyTransaction[] @relation("FromEntity")
  toTransactions   InterCompanyTransaction[] @relation("ToEntity")
}

model InterCompanyTransaction {
  id                 String    @id @default(cuid())
  fromEntityId       String
  fromEntity         Entity    @relation("FromEntity", fields: [fromEntityId], references: [id])
  toEntityId         String
  toEntity           Entity    @relation("ToEntity", fields: [toEntityId], references: [id])
  documentType       String // Invoice, Payment, Journal
  documentId         String
  documentNo         String
  amount             Int // จำนวนเงิน (สตางค์)
  description        String?
  eliminationEntryId String? // รายการกำจัดขั้นตอนรวม
  isEliminated       Boolean   @default(false)
  eliminatedAt       DateTime?
  eliminatedBy       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([fromEntityId])
  @@index([toEntityId])
  @@index([documentType, documentId])
}

// Consolidated Reporting adjustments
model ConsolidationAdjustment {
  id             String                      @id @default(cuid())
  year           Int
  month          Int
  type           ConsolidationAdjustmentType
  fromAccountId  String
  toAccountId    String
  amount         Int // จำนวนเงิน (สตางค์)
  description    String?
  journalEntryId String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
}

enum ConsolidationAdjustmentType {
  ELIMINATION // กำจัดรายการระหว่างกัน
  REALLOCATION // จัดสรรใหม่
  TRANSLATION // แปลงค่าเงิน
}

// ============================================
// Webhooks (Phase D: API Mastery)
// ============================================
model WebhookEndpoint {
  id            String            @id @default(cuid())
  name          String
  url           String
  events        String // Comma-separated list of events
  secret        String // For HMAC signature
  isActive      Boolean           @default(true)
  retryCount    Int               @default(3)
  lastTriggered DateTime?
  lastError     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deliveries    WebhookDelivery[]
}

model WebhookDelivery {
  id             String          @id @default(cuid())
  webhookId      String
  webhook        WebhookEndpoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event          String
  payload        String // JSON string
  responseStatus Int?
  responseBody   String?
  duration       Int // ms
  success        Boolean
  error          String?
  deliveredAt    DateTime        @default(now())

  @@index([webhookId])
  @@index([deliveredAt])
  @@index([event])
}

// ============================================
// API Request Analytics (Added for Phase D)
// ============================================
model ApiRequestLog {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  userId     String?
  sessionId  String?
  apiVersion String   @default("v1")
  method     String // GET, POST, PUT, DELETE, etc.
  path       String // API path
  query      String? // Query params (JSON)
  statusCode Int
  duration   Int // ms
  ipAddress  String
  userAgent  String?
  error      String?

  @@index([timestamp])
  @@index([userId])
  @@index([path])
  @@index([statusCode])
  @@index([apiVersion])
}

// ============================================
// API Rate Limit Tracking
// ============================================
model RateLimitLog {
  id           String    @id @default(cuid())
  identifier   String // IP or userId
  endpoint     String
  windowStart  DateTime
  requestCount Int       @default(0)
  blocked      Boolean   @default(false)
  blockedUntil DateTime?

  @@index([identifier, endpoint, windowStart])
  @@index([blocked])
}

// ============================================
// รายงานอัตโนมัติตามกำหนดเวลา (Scheduled Reports)
// ============================================
model ScheduledReport {
  id           String               @id @default(cuid())
  name         String
  reportType   String
  schedule     String // daily, weekly, monthly, quarterly, custom
  dayOfWeek    Int? // 0-6 for weekly (Sunday=0)
  dayOfMonth   Int? // 1-31 for monthly
  monthOfYear  Int? // 1-12 for quarterly
  time         String // HH:MM format
  enabled      Boolean              @default(true)
  parameters   Json // Report parameters as JSON (filters, date ranges, etc.)
  recipients   String // Comma-separated emails
  outputFormat String               @default("PDF") // PDF, EXCEL
  emailSubject String?
  emailBody    String?
  createdBy    String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  runs         ScheduledReportRun[]
}

model ScheduledReportRun {
  id                String          @id @default(cuid())
  scheduledReportId String
  scheduledReport   ScheduledReport @relation(fields: [scheduledReportId], references: [id], onDelete: Cascade)
  status            String // success, failed
  runAt             DateTime
  errorMessage      String?
  fileUrl           String?
  fileSize          Int? // File size in bytes
  generatedRecords  Int? // Number of records generated
  createdAt         DateTime        @default(now())

  @@index([scheduledReportId])
  @@index([status])
  @@index([runAt])
}

// ============================================
// บันทึกการตรวจสอบ / Audit Logging (Tamper-evident)
// ============================================
model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  userId      String
  user        User     @relation("AuditUser", fields: [userId], references: [id])
  action      String // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, VIEW, EXPORT
  entityType  String // Invoice, Receipt, Customer, Vendor, JournalEntry, etc
  entityId    String // ID of affected record
  beforeState Json? // Previous values (encrypted for sensitive fields)
  afterState  Json? // New values (encrypted for sensitive fields)
  ipAddress   String
  userAgent   String
  hash        String // Tamper-evident hash (SHA-256 chain)
  prevHash    String? // Hash of previous audit log entry

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([timestamp])
  @@index([hash])
}

// ============================================
// CSRF Tokens
// ============================================
model CsrfToken {
  id        String   @id @default(cuid())
  token     String   @unique
  sessionId String
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)

  @@index([token])
  @@index([sessionId])
  @@index([expiresAt])
}

// ============================================
// การตั้งค่าผู้ใช้ / User Preferences (Phase E)
// ============================================
model UserPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Theme & Appearance
  theme    String @default("system") // light, dark, system
  density  String @default("normal") // compact, normal, comfortable
  language String @default("th") // th, en

  // Default Settings
  pageSize       Int    @default(25) // 10, 25, 50, 100
  dateFormat     String @default("DD/MM/YYYY")
  currencyFormat String @default("THB")

  // Dashboard Layout
  dashboardLayout Json? // Store widget positions

  // Notifications
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// ตัวกรองที่บันทึกไว้ / Saved Filters (Phase E)
// ============================================
model SavedFilter {
  id        String   @id @default(cuid())
  userId    String
  name      String // e.g., "Overdue Invoices"
  module    String // e.g., "invoices", "products"
  filters   Json // Filter criteria
  isDefault Boolean  @default(false)
  isShared  Boolean  @default(false)
  sortField String?
  sortOrder String   @default("desc") // asc, desc
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([module])
}

// ============================================
// การแจ้งเตือน / Notifications (Phase E)
// ============================================
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType // info, success, warning, error
  title     String
  message   String
  module    String? // Related module
  recordId  String? // Related record
  isRead    Boolean          @default(false)
  readAt    DateTime?
  actionUrl String? // Deep link
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ============================================
// Purchase Request & Purchase Order System
// ============================================

// Enums
enum RequestPriority {
  URGENT       // ด่วนมาก
  HIGH         // สูง
  NORMAL       // ปกติ
  LOW          // ต่ำ
}

enum RequestStatus {
  DRAFT           // ร่าง
  PENDING         // รออนุมัติ
  APPROVED        // อนุมัติแล้ว
  REJECTED        // ปฏิเสธ
  CANCELLED       // ยกเลิก
  CONVERTED       // แปลงเป็น PO แล้ว
}

enum OrderStatus {
  DRAFT           // ร่าง
  PENDING         // รออนุมัติ
  APPROVED        // อนุมัติแล้ว
  SENT            // ส่งให้ผู้ขายแล้ว
  CONFIRMED       // ผู้ขายยืนยันแล้ว
  SHIPPED         // จัดส่งแล้ว
  RECEIVED        // รับสินค้าแล้ว
  CANCELLED       // ยกเลิก
  CLOSED          // ปิดบัญชีแล้ว
}

enum BudgetStatus {
  DRAFT       // ร่าง
  ACTIVE      // ใช้งานอยู่
  CLOSED      // ปิดแล้ว
  LOCKED      // ล็อก
}

// Department Model
model Department {
  id              String              @id @default(cuid())
  code            String              @unique // รหัสแผนก
  name            String              // ชื่อแผนก
  nameEn          String?             // ชื่อภาษาอังกฤษ
  managerId       String?             // ผู้จัดการแผนก
  manager         User?               @relation("DeptManager", fields: [managerId], references: [id])
  parentId        String?             // แผนกแม่
  parent          Department?         @relation("DeptHierarchy", fields: [parentId], references: [id])
  children        Department[]        @relation("DeptHierarchy")
  costCenter      String?             // ศูนย์ต้นทุน
  location        String?             // ที่ตั้ง
  isActive        Boolean             @default(true)
  notes           String?             // หมายเหตุ

  // Relations
  purchaseRequests PurchaseRequest[] @relation("PRDepartment")
  budgets         DepartmentBudget[]

  createdById     String
  createdBy       User                @relation("DeptCreator", fields: [createdById], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([parentId])
  @@index([managerId])
  @@index([isActive])
}

// Department Budget Model (for PR/PO system)
model DepartmentBudget {
  id              String          @id @default(cuid())
  code            String          @unique // รหัสงบประมาณ
  name            String          // ชื่องบประมาณ
  fiscalYear      Int             // ปีงบประมาณ
  departmentId    String?         // แผนก
  department      Department?     @relation(fields: [departmentId], references: [id])

  // วงเงิน
  allocatedAmount Int             @default(0) // วงเงินจัดสรร (สตางค์)
  usedAmount      Int             @default(0) // วงเงินที่ใช้ไป (สตางค์)
  remainingAmount Int             @default(0) // วงเงินคงเหลือ (สตางค์)

  startDate       DateTime        // วันที่เริ่ม
  endDate         DateTime        // วันที่สิ้นสุด
  status          BudgetStatus    @default(ACTIVE)

  notes           String?         // หมายเหตุ

  createdById     String
  createdBy       User            @relation("DeptBudgetCreator", fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  purchaseRequests PurchaseRequest[] @relation("PRBudget")
  purchaseOrders   PurchaseOrder[]   @relation("POBudget")

  @@index([fiscalYear])
  @@index([departmentId])
  @@index([status])
  @@index([startDate, endDate])
}

// Purchase Request Model
model PurchaseRequest {
  id                String              @id @default(cuid())
  requestNo         String              @unique // เลขที่ PR (PR202603-001)
  requestDate       DateTime            @default(now()) // วันที่ขอซื้อ

  // ผู้ขอซื้อ
  requestedBy       String
  requestedByUser   User                @relation("PRCreator", fields: [requestedBy], references: [id])
  departmentId      String?
  departmentData    Department?         @relation("PRDepartment", fields: [departmentId], references: [id])

  // ผู้อนุมัติ
  approvedBy        String?             // ผู้อนุมัติ
  approvedByUser    User?               @relation("PRApprover", fields: [approvedBy], references: [id])
  approvedAt        DateTime?           // วันที่อนุมัติ
  approvalNotes     String?             // หมายเหตุการอนุมัติ

  // รายละเอียดการขอซื้อ
  requiredDate      DateTime?           // วันที่ต้องการสินค้า
  reason            String?             // เหตุผลการขอซื้อ
  priority          RequestPriority     @default(NORMAL) // ความสำคัญ

  // งบประมาณ
  budgetId          String?             // อ้างอิงงบประมาณ
  budget            DepartmentBudget?   @relation("PRBudget", fields: [budgetId], references: [id])
  budgetAmount      Int?                // วงเงินงบประมาณ (สตางค์)
  estimatedAmount   Int                 @default(0) // วงเงินประมาณการ (สตางค์)

  // สถานะ
  status            RequestStatus       @default(DRAFT)
  submittedAt       DateTime?           // วันที่ส่งอนุมัติ

  // เชื่อมโยงกับ PO
  purchaseOrderId   String?             @unique // อ้างอิง PO
  purchaseOrder     PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id])

  // รายการสินค้า
  lines             PurchaseRequestLine[]

  // เอกสารและบันทึก
  notes             String?             // หมายเหตุ
  attachments       Json?               // เอกสารแนบ
  internalNotes     String?             // บันทึกภายใน

  // Audit
  updatedById       String?
  updatedBy         User?               @relation("PRUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  deletedBy         String?

  @@index([requestedBy])
  @@index([status])
  @@index([departmentId])
  @@index([requestDate])
  @@index([createdAt])
  @@index([priority])
}

// Purchase Request Line Model
model PurchaseRequestLine {
  id              String           @id @default(cuid())
  requestId       String
  request         PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  lineNo          Int              // ลำดับรายการ
  productId       String?          // สินค้า
  product         Product?         @relation("PRLineProduct", fields: [productId], references: [id])
  description     String           // รายการสินค้า
  quantity        Float            // จำนวนที่ขอ
  unit            String           @default("ชิ้น") // หน่วย
  unitPrice       Float            @default(0) // ราคาประมาณการ
  discount        Float            @default(0) // ส่วนลด
  vatRate         Float            @default(7) // อัตรา VAT %
  vatAmount       Float            @default(0) // ภาษีมูลค่าเพิ่ม
  amount          Float            @default(0) // จำนวนเงิน

  // ข้อมูลเพิ่มเติม
  suggestedVendor String?         // ผู้ขายที่แนะนำ
  specUrl         String?          // URL รายละเอียดสินค้า
  notes           String?          // หมายเหตุ

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([requestId])
  @@index([productId])
}

// Purchase Order Model
model PurchaseOrder {
  id                String              @id @default(cuid())
  orderNo           String              @unique // เลขที่ PO PO202603-001
  orderDate         DateTime            @default(now()) // วันที่สั่งซื้อ
  expectedDate      DateTime?           // วันที่คาดว่าจะได้รับสินค้า

  // ข้อมูลผู้ขาย
  vendorId          String
  vendor            Vendor              @relation("POVendor", fields: [vendorId], references: [id], onDelete: Restrict)
  vendorContact     String?             // ผู้ติดต่อ
  vendorEmail       String?             // อีเมลผู้ขาย
  vendorPhone       String?             // โทรศัพท์ผู้ขาย
  vendorAddress     String?             // ที่อยู่จัดส่ง

  // อ้างอิง PR
  purchaseRequestId String?            @unique // อ้างอิง PR
  purchaseRequest   PurchaseRequest?    @relation

  // รายละเอียดการสั่งซื้อ
  shippingTerms     String?             // เงื่อนไขการจัดส่ง
  paymentTerms      String?             // เงื่อนไขการชำระเงิน
  deliveryAddress   String?             // สถานที่จัดส่ง

  // งบประมาณ
  budgetId          String?             // อ้างอิงงบประมาณ
  budget            DepartmentBudget?   @relation("POBudget", fields: [budgetId], references: [id])
  budgetAmount      Int?                // วงเงินงบประมาณ (สตางค์)

  // ยอดรวม
  subtotal          Int                 @default(0) // มูลค่าก่อน VAT (สตางค์)
  vatRate           Float               @default(7) // อัตรา VAT %
  vatAmount         Int                 @default(0) // ภาษีมูลค่าเพิ่ม (สตางค์)
  totalAmount       Int                 @default(0) // ยอดรวม (สตางค์)
  discountAmount    Int                 @default(0) // ส่วนลด (สตางค์)

  // สถานะ
  status            OrderStatus         @default(DRAFT)
  submittedAt       DateTime?           // วันที่ส่งผู้ขาย
  confirmedAt       DateTime?           // วันที่ยืนยันจากผู้ขาย
  shippedAt         DateTime?           // วันที่จัดส่ง
  receivedAt        DateTime?           // วันที่รับสินค้า

  // เชื่อมโยงกับใบซื้อ
  purchaseInvoiceId String?            @unique // อ้างอิงใบซื้อ
  purchaseInvoice   PurchaseInvoice?    @relation("POInvoice", fields: [purchaseInvoiceId], references: [id])

  // รายการสินค้า
  lines             PurchaseOrderLine[]

  // เอกสารและบันทึก
  notes             String?             // หมายเหตุ
  internalNotes     String?             // บันทึกภายใน
  attachments       Json?               // เอกสารแนบ
  vendorNotes       String?             // หมายเหตุสำหรับผู้ขาย

  // Audit
  createdById       String
  createdBy         User                @relation("POCreator", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?               @relation("POUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  deletedBy         String?

  @@index([vendorId])
  @@index([status])
  @@index([orderDate])
  @@index([createdById])
  @@index([purchaseRequestId])
  @@index([submittedAt])
}

// Purchase Order Line Model
model PurchaseOrderLine {
  id              String         @id @default(cuid())
  orderId        String
  order          PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  lineNo          Int            // ลำดับรายการ
  productId       String?        // สินค้า
  product         Product?       @relation("POLineProduct", fields: [productId], references: [id])
  description     String         // รายการสินค้า
  quantity        Float          // จำนวนสั่งซื้อ
  receivedQty     Float          @default(0) // จำนวนที่รับแล้ว
  unit            String         @default("ชิ้น") // หน่วย
  unitPrice       Float          @default(0) // ราคาต่อหน่วย
  discount        Float          @default(0) // ส่วนลด
  vatRate         Float          @default(7) // อัตรา VAT %
  vatAmount       Float          @default(0) // ภาษีมูลค่าเพิ่ม
  amount          Float          @default(0) // จำนวนเงิน

  // ข้อมูลเพิ่มเติม
  specUrl         String?        // URL รายละเอียดสินค้า
  notes           String?        // หมายเหตุ

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([orderId])
  @@index([productId])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

// ============================================
// รายการล่าสุด / Recent Items (Phase E)
// ============================================
model RecentItem {
  id         String   @id @default(cuid())
  userId     String
  module     String // e.g., "invoice", "customer"
  recordId   String
  recordType String // Type of record
  recordName String // Display name
  action     String // view, edit, create
  accessedAt DateTime @default(now())

  @@unique([userId, module, recordId])
  @@index([userId])
  @@index([module])
  @@index([accessedAt])
}

// ============================================
// เอกสารที่ถูกล็อก / Document Locks (Phase E - Collaboration)
// ============================================
model DocumentLock {
  id        String   @id @default(cuid())
  module    String // e.g., "invoice", "journal"
  recordId  String
  userId    String
  userName  String
  lockedAt  DateTime @default(now())
  expiresAt DateTime // Auto-expire after timeout
  sessionId String // WebSocket session

  @@unique([module, recordId])
  @@index([module, recordId])
  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// กิจกรรมแบบ Real-time / Activity Feed (Phase E)
// ============================================
model ActivityFeed {
  id         String   @id @default(cuid())
  userId     String? // Who performed the action (null for system)
  userName   String?
  action     String // created, updated, deleted, viewed
  module     String
  recordId   String?
  recordName String?
  details    Json? // Additional context
  isSystem   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([module])
  @@index([createdAt])
  @@index([userId])
}

// ============================================
// User Sessions (for concurrent session limiting)
// ============================================

// ============================================
// User Sessions (for concurrent session limiting)
// ============================================
model UserSession {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  ipAddress    String
  userAgent    String
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  isValid      Boolean  @default(true)
  rotatedFrom  String? // Previous session token if rotated

  @@index([userId])
  @@index([sessionToken])
  @@index([expiresAt])
  @@index([isValid])
}

// ============================================
// Invoice Comments System
// ============================================
model InvoiceComment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  userId      String
  content     String   // Comment content (Thai/English)
  isInternal  Boolean  @default(false) // Internal-only comment
  parentId    String?  // Parent comment ID for threading
  parent      InvoiceComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     InvoiceComment[] @relation("CommentReplies")
  mentions    Json? // Array of user IDs mentioned in comment (@mentions)
  attachments Json?    // File attachments [{name, url, size, type}]
  resolved    Boolean  @default(false) // Is the comment resolved?
  resolvedAt  DateTime? // When the comment was resolved
  resolvedBy  String?  // User ID who resolved the comment
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([invoiceId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
  @@index([resolved])
}

// ============================================
// Invoice Line Item Audit Trail
// ============================================
model InvoiceLineItemAudit {
  id              String      @id @default(cuid())
  lineItemId      String
  lineItem        InvoiceLine @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  action          String // CREATED, UPDATED, DELETED
  field           String? // Which field changed (description, quantity, unitPrice, etc.)
  oldValue        String? // Previous value (serialized)
  newValue        String? // New value (serialized)

  // Structured fields for common changes (enhanced analytics)
  beforeQuantity  Float?
  afterQuantity   Float?
  quantityDiff    Float? // afterQuantity - beforeQuantity

  beforeUnitPrice Int? // Before change (in Satang)
  afterUnitPrice  Int? // After change (in Satang)
  unitPriceDiff   Int? // Difference (in Satang)

  beforeDiscount  Int?
  afterDiscount   Int?
  discountDiff    Int?

  beforeDescription String?
  afterDescription  String?

  changeType      String? // EDIT, REVERT, CORRECTION
  changeReason    String? // Reason for change (optional)
  changedById     String
  changedByName   String? // User name for quick reference
  createdAt       DateTime @default(now())

  @@index([lineItemId])
  @@index([createdAt])
  @@index([changedById])
  @@index([action])
}

// ============================================
// Related Documents (links between invoices, receipts, credit notes, etc.)
// ============================================
model RelatedDocument {
  id              String   @id @default(cuid())
  sourceModule    String // invoice, receipt, credit_note, debit_note, payment
  sourceId        String // ID of the source document
  relatedModule   String // Type of related document
  relatedId       String // ID of related document
  relationType    String // LINKS, CANCELS, REPLACES, REFUNDS, ADJUSTS
  notes           String? // Notes about the relationship
  createdById     String?
  createdAt       DateTime @default(now())

  @@unique([sourceModule, sourceId, relatedModule, relatedId])
  @@index([sourceModule, sourceId])
  @@index([relatedModule, relatedId])
  @@index([relationType])
}

// ============================================
// Comment Notifications
// ============================================
model CommentNotification {
  id          String   @id @default(cuid())
  userId      String // User to notify
  commentId   String // The comment that triggered notification
  invoiceId   String // Related invoice
  type        String // MENTION, REPLY, RESOLVED
  isRead      Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@index([commentId])
  @@index([invoiceId])
  @@index([createdAt])
}
