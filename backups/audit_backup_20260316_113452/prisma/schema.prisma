// Thai Accounting ERP System - Prisma Schema
// โปรแกรมบัญชีมาตรฐานไทย

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// ข้อมูลบริษัท / Company Profile
// ============================================
model Company {
  id              String   @id @default(cuid())
  name            String // ชื่อบริษัท
  nameEn          String? // ชื่อภาษาอังกฤษ
  taxId           String? // เลขประจำตัวผู้เสียภาษี
  branchCode      String? // รหัสสาขา
  address         String? // ที่อยู่
  subDistrict     String? // แขวง/ตำบล
  district        String? // เขต/อำเภอ
  province        String? // จังหวัด
  postalCode      String? // รหัสไปรษณีย์
  phone           String? // โทรศัพท์
  fax             String? // โทรสาร
  email           String? // อีเมล
  website         String? // เว็บไซต์
  logo            String? // โลโก้
  fiscalYearStart Int      @default(1) // เริ่มปีบัญชี (เดือน)
  metadata        Json? // ข้อมูลส่วนขยาย
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  systemSettings  SystemSettings?
}

// ============================================
// ตั้งค่าระบบ / System Settings
// ============================================
model SystemSettings {
  id              String   @id @default(cuid())
  companyId       String   @unique
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vatRate         Float    @default(7) // อัตราภาษีมูลค่าเพิ่ม
  whtPnd53Service Float    @default(3) // อัตราภาษีหัก ณ ที่จ่าย ค่าบริการ
  whtPnd53Rent    Float    @default(5) // อัตราภาษีหัก ณ ที่จ่าย ค่าเช่า
  whtPnd53Prof    Float    @default(3) // อัตราภาษีหัก ณ ที่จ่าย ค่าบริการวิชาชีพ
  whtPnd53Contract Float   @default(1) // อัตราภาษีหัก ณ ที่จ่าย ค่าจ้างทำของ
  whtPnd53Advert  Float    @default(2) // อัตราภาษีหัก ณ ที่จ่าย ค่าโฆษณา
  metadata        Json? // ข้อมูลส่วนขยาย
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// ผังบัญชี / Chart of Accounts
// ============================================
model ChartOfAccount {
  id           String           @id @default(cuid())
  code         String           @unique // รหัสบัญชี (1000, 1100, 1110, etc.)
  name         String // ชื่อบัญชี
  nameEn       String? // ชื่อภาษาอังกฤษ
  type         AccountType // ประเภทบัญชี
  level        Int              @default(1) // ระดับ (1-4)
  parentId     String? // บัญชีแม่
  parent       ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     ChartOfAccount[] @relation("AccountHierarchy")
  isDetail     Boolean          @default(true) // เป็นบัญชีรายละเอียดหรือไม่
  isSystem     Boolean          @default(false) // เป็นบัญชีระบบหรือไม่
  isActive     Boolean          @default(true)
  notes        String? // หมายเหตุ
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  journalLines JournalLine[]
}

enum AccountType {
  ASSET // สินทรัพย์ (1xxx)
  LIABILITY // หนี้สิน (2xxx)
  EQUITY // ทุน (3xxx)
  REVENUE // รายได้ (4xxx)
  EXPENSE // ค่าใช้จ่าย (5xxx)
}

// ============================================
// บันทึกบัญชี / Journal Entry
// ============================================
model JournalEntry {
  id           String        @id @default(cuid())
  entryNo      String        @unique // เลขที่บันทึก
  date         DateTime // วันที่
  description  String? // รายการ
  reference    String? // เอกสารอ้างอิง
  documentType String? // ประเภทเอกสาร
  documentId   String? // ID เอกสารต้นทาง
  totalDebit   Float         @default(0) // รวมเดบิต
  totalCredit  Float         @default(0) // รวมเครดิต
  status       EntryStatus   @default(DRAFT)
  isAdjustment Boolean       @default(false) // รายการปรับปรุง
  isReversing  Boolean       @default(false) // รายการย้อนกลับ
  reversingId  String? // ID ของรายการที่ย้อน
  createdById     String? // ผู้สร้าง
  approvedById    String? // ผู้อนุมัติ
  approvedAt      DateTime? // วันที่อนุมัติ
  idempotencyKey  String? @unique // ✅ FIXED: Prevent duplicate journal entries
  notes           String? // หมายเหตุ
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lines        JournalLine[]
  invoices     Invoice[]              @relation("InvoiceJournal")
  purchaseInvoices PurchaseInvoice[]  @relation("PurchaseInvoiceJournal")
  receipts     Receipt[]              @relation("ReceiptJournal")
  payments     Payment[]              @relation("PaymentJournal")
  creditNotes  CreditNote[]           @relation("CreditNoteJournal")
  debitNotes   DebitNote[]            @relation("DebitNoteJournal")
  payrollRuns  PayrollRun[]           @relation("PayrollRunJournal")
  cheques      Cheque[]               @relation("ChequeJournal")
  pettyCashVouchers PettyCashVoucher[] @relation("PettyCashVoucherJournal")
  stockTakes   StockTake[]            @relation("StockTakeJournal")
}

model JournalLine {
  id          String         @id @default(cuid())
  entryId     String
  entry       JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lineNo      Int // ลำดับ
  accountId   String
  account     ChartOfAccount @relation(fields: [accountId], references: [id])
  description String? // รายการ
  debit       Float          @default(0) // เดบิต
  credit      Float          @default(0) // เครดิต
  reference   String? // เอกสารอ้างอิง
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([entryId])
  @@index([accountId])
}

enum EntryStatus {
  DRAFT // ร่าง
  POSTED // ลงบัญชีแล้ว
  REVERSED // ย้อนกลับแล้ว
}

// ============================================
// ลูกค้า / Customers
// ============================================
model Customer {
  id            String       @id @default(cuid())
  code          String       @unique // รหัสลูกค้า
  name          String // ชื่อลูกค้า
  nameEn        String? // ชื่อภาษาอังกฤษ
  taxId         String? // เลขประจำตัวผู้เสียภาษี
  branchCode    String? // รหัสสาขา
  address       String? // ที่อยู่
  subDistrict   String? // แขวง/ตำบล
  district      String? // เขต/อำเภอ
  province      String? // จังหวัด
  postalCode    String? // รหัสไปรษณีย์
  phone         String? // โทรศัพท์
  fax           String? // โทรสาร
  email         String? // อีเมล
  website       String? // เว็บไซต์
  contactName   String? // ชื่อผู้ติดต่อ
  contactPhone  String? // โทรศัพท์ผู้ติดต่อ
  creditLimit   Float        @default(0) // วงเงินเครดิต
  creditDays    Int          @default(30) // เครดิต (วัน)
  isActive      Boolean      @default(true)
  notes         String? // หมายเหตุ
  externalRefId String?      @unique // สำหรับเชื่อมต่อระบบภายนอก (CRM/POS)
  metadata      Json? // ข้อมูลส่วนขยาย
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  invoices      Invoice[]
  receipts      Receipt[]
  creditNotes   CreditNote[]
}

// ============================================
// ผู้ขาย / Vendors
// ============================================
model Vendor {
  id               String            @id @default(cuid())
  code             String            @unique // รหัสผู้ขาย
  name             String // ชื่อผู้ขาย
  nameEn           String? // ชื่อภาษาอังกฤษ
  taxId            String? // เลขประจำตัวผู้เสียภาษี
  branchCode       String? // รหัสสาขา
  address          String? // ที่อยู่
  subDistrict      String? // แขวง/ตำบล
  district         String? // เขต/อำเภอ
  province         String? // จังหวัด
  postalCode       String? // รหัสไปรษณีย์
  phone            String? // โทรศัพท์
  fax              String? // โทรสาร
  email            String? // อีเมล
  website          String? // เว็บไซต์
  contactName      String? // ชื่อผู้ติดต่อ
  contactPhone     String? // โทรศัพท์ผู้ติดต่อ
  bankName         String? // ชื่อธนาคาร
  bankAccount      String? // เลขที่บัญชี
  bankAccountName  String? // ชื่อบัญชี
  creditDays       Int               @default(30) // เครดิต (วัน)
  isActive         Boolean           @default(true)
  notes            String? // หมายเหตุ
  externalRefId    String?           @unique // สำหรับเชื่อมต่อระบบภายนอก
  metadata         Json? // ข้อมูลส่วนขยาย
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  purchaseInvoices PurchaseInvoice[]
  payments         Payment[]
  debitNotes       DebitNote[]
}

// ============================================
// สินค้า/บริการ / Products & Services
// ============================================
model Product {
  id                   String                @id @default(cuid())
  code                 String                @unique // รหัสสินค้า
  name                 String // ชื่อสินค้า
  nameEn               String? // ชื่อภาษาอังกฤษ
  description          String? // รายละเอียด
  category             String? // หมวดหมู่
  unit                 String                @default("ชิ้น") // หน่วย
  type                 ProductType           @default(PRODUCT) // ประเภท
  salePrice            Float                 @default(0) // ราคาขาย
  costPrice            Float                 @default(0) // ราคาทุน
  vatRate              Float                 @default(7) // อัตรา VAT (%)
  vatType              VatType               @default(EXCLUSIVE) // ประเภท VAT
  isInventory          Boolean               @default(false) // ติดตามสต็อก
  quantity             Float                 @default(0) // จำนวนคงเหลือ
  minQuantity          Float                 @default(0) // จำนวนต่ำสุด
  incomeType           String? // ประเภทรายได้ (สำหรับหัก ณ ที่จ่าย 50 ทวิ)
  costingMethod        CostingMethod         @default(WEIGHTED_AVERAGE)
  isActive             Boolean               @default(true)
  notes                String? // หมายเหตุ
  metadata             Json? // ข้อมูลส่วนขยาย
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  invoiceLines         InvoiceLine[]
  purchaseLines        PurchaseInvoiceLine[]
  stockBalances        StockBalance[]
  stockMovements       StockMovement[]
  stockTransferLines   StockTransferLine[]
  stockTakeLines       StockTakeLine[]
  productCostHistories ProductCostHistory[]
}

enum CostingMethod {
  FIFO
  WEIGHTED_AVERAGE
}

enum ProductType {
  PRODUCT // สินค้า
  SERVICE // บริการ
}

enum VatType {
  EXCLUSIVE // ยังไม่รวม VAT
  INCLUSIVE // รวม VAT แล้ว
  NONE // ไม่มี VAT
}

// ============================================
// ใบกำกับภาษี / Tax Invoice
// ============================================
model Invoice {
  id                String        @id @default(cuid())
  invoiceNo         String        @unique // เลขที่ใบกำกับภาษี
  invoiceDate       DateTime // วันที่ออกใบกำกับภาษี
  dueDate           DateTime? // วันครบกำหนด
  customerId        String
  customer          Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  type              InvoiceType   @default(TAX_INVOICE)
  reference         String? // เอกสารอ้างอิง
  poNumber          String? // เลขที่ใบสั่งซื้อ
  subtotal          Float         @default(0) // มูลค่าก่อน VAT
  vatRate           Float         @default(7) // อัตรา VAT
  vatAmount         Float         @default(0) // ภาษีมูลค่าเพิ่ม
  totalAmount       Float         @default(0) // ยอดรวม
  discountAmount    Float         @default(0) // ส่วนลด
  discountPercent   Float         @default(0) // ส่วนลด %
  withholdingRate   Float         @default(0) // อัตราภาษีหัก ณ ที่จ่าย
  withholdingAmount Float         @default(0) // ภาษีหัก ณ ที่จ่าย
  netAmount         Float         @default(0) // ยอดสุทธิ
  paidAmount        Float         @default(0) // ยอดชำระแล้ว
  status            InvoiceStatus @default(DRAFT)
  notes             String? // หมายเหตุ
  internalNotes     String? // หมายเหตุภายใน
  terms             String? // เงื่อนไข
  sourceChannel     String? // ช่องทางที่มา (เช่น POS, WEB, API)
  metadata          Json? // ข้อมูลส่วนขยาย
  createdById       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  lines             InvoiceLine[]
  receiptAllocations ReceiptAllocation[]
  journalEntryId    String? // ID บันทึกบัญชี
  journalEntry      JournalEntry?  @relation("InvoiceJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  creditNotes       CreditNote[] // ใบลดหนี้ที่อ้างอิงใบกำกับภาษีนี้
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineNo      Int // ลำดับ
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String // รายการ
  quantity    Float    @default(1) // จำนวน
  unit        String   @default("ชิ้น") // หน่วย
  unitPrice   Float    @default(0) // ราคาต่อหน่วย
  discount    Float    @default(0) // ส่วนลด
  amount      Float    @default(0) // จำนวนเงิน
  vatRate     Float    @default(7) // อัตรา VAT
  vatAmount   Float    @default(0) // ภาษีมูลค่าเพิ่ม
  notes       String? // หมายเหตุ
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([invoiceId])
}

enum InvoiceType {
  TAX_INVOICE // ใบกำกับภาษี
  RECEIPT // ใบเสร็จรับเงิน
  DELIVERY_NOTE // ใบส่งของ
  CREDIT_NOTE // ใบลดหนี้
  DEBIT_NOTE // ใบเพิ่มหนี้
}

enum InvoiceStatus {
  DRAFT // ร่าง
  ISSUED // ออกแล้ว
  PARTIAL // รับชำระแล้วบางส่วน
  PAID // รับชำระเต็มจำนวน
  CANCELLED // ยกเลิก
}

// ============================================
// ใบเสร็จรับเงิน / Receipt
// ============================================
model Receipt {
  id             String              @id @default(cuid())
  receiptNo      String              @unique // เลขที่ใบเสร็จ
  receiptDate    DateTime // วันที่รับเงิน
  customerId     String
  customer       Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  paymentMethod  PaymentMethod       @default(CASH)
  bankAccountId  String? // ID บัญชีธนาคาร
  bankAccount    BankAccount?        @relation(fields: [bankAccountId], references: [id])
  chequeNo       String? // เลขที่เช็ค
  chequeDate     DateTime? // วันที่เช็ค
  amount         Float               @default(0) // จำนวนเงินรับโดยสิ้นเชิง
  whtAmount      Float               @default(0) // ภาษีหัก ณ ที่จ่ายรวม
  unallocated    Float               @default(0) // ยอดที่ยังไม่ได้จัดจ่าย (เครดิตลูกค้า)
  notes          String? // หมายเหตุ
  status         ReceiptStatus       @default(DRAFT)
  journalEntryId String? // ID บันทึกบัญชี
  idempotencyKey  String? @unique // ✅ FIXED: Prevent duplicate receipts
  journalEntry   JournalEntry?       @relation("ReceiptJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  allocations    ReceiptAllocation[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model ReceiptAllocation {
  id          String    @id @default(cuid())
  receiptId   String
  invoiceId   String
  amount      Float     // จำนวนเงินที่จ่าย
  whtRate     Float     @default(0) // อัตราหัก ณ ที่จ่าย (%)
  whtAmount   Float     @default(0) // ภาษีหัก ณ ที่จ่าย
  receipt     Receipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  invoice     Invoice   @relation(fields: [invoiceId], references: [id])
  createdAt   DateTime  @default(now())
}

enum PaymentMethod {
  CASH // เงินสด
  CHEQUE // เช็ค
  TRANSFER // โอนเงิน
  CREDIT // บัตรเครดิต
  OTHER // อื่นๆ
}

enum ReceiptStatus {
  DRAFT // ร่าง
  POSTED // ลงบัญชีแล้ว
  CANCELLED // ยกเลิก
}

// ============================================
// ใบลดหนี้ / Credit Note
// ============================================
model CreditNote {
  id             String           @id @default(cuid())
  creditNoteNo   String           @unique // เลขที่ใบลดหนี้
  creditNoteDate DateTime // วันที่ออก
  customerId     String
  customer       Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  invoiceId      String? // อ้างอิงใบกำกับภาษี
  invoice        Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  reason         String? // เหตุผล
  subtotal       Float            @default(0) // มูลค่าก่อน VAT
  vatRate        Float            @default(7) // อัตรา VAT
  vatAmount      Float            @default(0) // ภาษีมูลค่าเพิ่ม
  totalAmount    Float            @default(0) // ยอดรวม
  status         CreditNoteStatus @default(ISSUED)
  notes          String? // หมายเหตุ
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  journalEntryId String? // ID บันทึกบัญชี
  journalEntry  JournalEntry?  @relation("CreditNoteJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
}

enum CreditNoteStatus {
  ISSUED // ออกแล้ว
  CANCELLED // ยกเลิก
}

// ============================================
// ใบเพิ่มหนี้ / Debit Note
// ============================================
model DebitNote {
  id             String          @id @default(cuid())
  debitNoteNo    String          @unique // เลขที่ใบเพิ่มหนี้
  debitNoteDate  DateTime // วันที่ออก
  vendorId       String
  vendor         Vendor          @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  invoiceId      String? // อ้างอิงใบซื้อ
  purchaseInvoice PurchaseInvoice? @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  reason         String? // เหตุผล
  subtotal       Float           @default(0) // มูลค่าก่อน VAT
  vatRate        Float           @default(7) // อัตรา VAT
  vatAmount      Float           @default(0) // ภาษีมูลค่าเพิ่ม
  totalAmount    Float           @default(0) // ยอดรวม
  status         DebitNoteStatus @default(ISSUED)
  notes          String? // หมายเหตุ
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  journalEntryId String? // ID บันทึกบัญชี
  journalEntry  JournalEntry?  @relation("DebitNoteJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
}

enum DebitNoteStatus {
  ISSUED // ออกแล้ว
  CANCELLED // ยกเลิก
}

// ============================================
// ใบซื้อ / Purchase Invoice
// ============================================
model PurchaseInvoice {
  id                String                @id @default(cuid())
  invoiceNo         String                @unique // เลขที่ใบซื้อ
  vendorInvoiceNo   String? // เลขที่ใบกำกับภาษีของผู้ขาย
  invoiceDate       DateTime // วันที่ใบกำกับภาษี
  dueDate           DateTime? // วันครบกำหนด
  vendorId          String
  vendor            Vendor                @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  type              InvoiceType           @default(TAX_INVOICE)
  reference         String? // เอกสารอ้างอิง
  poNumber          String? // เลขที่ใบสั่งซื้อ
  subtotal          Float                 @default(0) // มูลค่าก่อน VAT
  vatRate           Float                 @default(7) // อัตรา VAT
  vatAmount         Float                 @default(0) // ภาษีมูลค่าเพิ่ม
  totalAmount       Float                 @default(0) // ยอดรวม
  discountAmount    Float                 @default(0) // ส่วนลด
  withholdingRate   Float                 @default(0) // อัตราภาษีหัก ณ ที่จ่าย
  withholdingAmount Float                 @default(0) // ภาษีหัก ณ ที่จ่าย
  netAmount         Float                 @default(0) // ยอดสุทธิ
  paidAmount        Float                 @default(0) // ยอดชำระแล้ว
  status            InvoiceStatus         @default(DRAFT)
  notes             String? // หมายเหตุ
  internalNotes     String? // หมายเหตุภายใน
  sourceChannel     String? // ช่องทางที่มา (เช่น POS, WEB, API)
  metadata          Json? // ข้อมูลส่วนขยาย
  createdById       String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  lines             PurchaseInvoiceLine[]
  paymentAllocations PaymentAllocation[] @relation("PaymentAllocations")
  journalEntryId    String? // ID บันทึกบัญชี
  journalEntry      JournalEntry?  @relation("PurchaseInvoiceJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  debitNotes        DebitNote[] // ใบเพิ่มหนี้ที่อ้างอิงใบซื้อนี้
}

model PurchaseInvoiceLine {
  id          String          @id @default(cuid())
  purchaseId  String
  purchase    PurchaseInvoice @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  lineNo      Int // ลำดับ
  productId   String?
  product     Product?        @relation(fields: [productId], references: [id])
  description String // รายการ
  quantity    Float           @default(1) // จำนวน
  unit        String          @default("ชิ้น") // หน่วย
  unitPrice   Float           @default(0) // ราคาต่อหน่วย
  discount    Float           @default(0) // ส่วนลด
  amount      Float           @default(0) // จำนวนเงิน
  vatRate     Float           @default(7) // อัตรา VAT
  vatAmount   Float           @default(0) // ภาษีมูลค่าเพิ่ม
  notes       String? // หมายเหตุ
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([purchaseId])
}

// ============================================
// ใบจ่ายเงิน / Payment (AP Payments)
// ============================================
model Payment {
  id             String              @id @default(cuid())
  paymentNo      String              @unique // เลขที่ใบจ่ายเงิน
  paymentDate    DateTime // วันที่จ่ายเงิน
  vendorId       String
  vendor         Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  paymentMethod  PaymentMethod       @default(CASH)
  bankAccountId  String?
  bankAccount    BankAccount?        @relation("PaymentBankAccount", fields: [bankAccountId], references: [id])
  chequeNo       String? // เลขที่เช็ค
  chequeDate     DateTime? // วันที่เช็ค
  amount         Float               @default(0) // จำนวนเงินรวม
  whtAmount      Float               @default(0) // ภาษีหัก ณ ที่จ่ายรวม
  unallocated    Float               @default(0) // ยอดคงเหลือ (เครดิตเจ้าหนี้)
  notes          String? // หมายเหตุ
  status         PaymentStatus       @default(DRAFT)
  createdById    String?
  idempotencyKey  String? @unique // ✅ FIXED: Prevent duplicate payments
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  journalEntryId String? // ID บันทึกบัญชี
  journalEntry  JournalEntry?       @relation("PaymentJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  allocations    PaymentAllocation[]
  cheques        Cheque[]            @relation("PaymentCheque")
}

model PaymentAllocation {
  id          String          @id @default(cuid())
  paymentId   String
  payment     Payment         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId   String
  invoice     PurchaseInvoice @relation("PaymentAllocations", fields: [invoiceId], references: [id], onDelete: Restrict)
  amount      Float // จำนวนเงินที่จ่าย
  whtRate     Float           @default(0) // อัตราหัก ณ ที่จ่าย (%)
  whtAmount   Float           @default(0) // ภาษีหัก ณ ที่จ่าย
  notes       String?
  createdAt   DateTime        @default(now())

  @@index([paymentId])
  @@index([invoiceId])
}

enum PaymentStatus {
  DRAFT // ร่าง
  POSTED // ลงบัญชีแล้ว
  CANCELLED // ยกเลิก
}


// ============================================
// ภาษีมูลค่าเพิ่ม / VAT Records
// ============================================
model VatRecord {
  id            String          @id @default(cuid())
  type          VatRecordType // ประเภท
  documentNo    String // เลขที่เอกสาร
  documentDate  DateTime // วันที่
  documentType  String? // ประเภทเอกสาร
  referenceId   String? // ID เอกสารอ้างอิง
  customerId    String? // ID ลูกค้า
  customerName  String? // ชื่อลูกค้า
  customerTaxId String? // เลขประจำตัวผู้เสียภาษีลูกค้า
  vendorId      String? // ID ผู้ขาย
  vendorName    String? // ชื่อผู้ขาย
  vendorTaxId   String? // เลขประจำตัวผู้เสียภาษีผู้ขาย
  description   String? // รายการ
  subtotal      Float           @default(0) // มูลค่าก่อน VAT
  vatRate       Float           @default(7) // อัตรา VAT
  vatAmount     Float           @default(0) // ภาษีมูลค่าเพิ่ม
  totalAmount   Float           @default(0) // ยอดรวม
  taxMonth      Int // เดือนที่ยื่นภาษี
  taxYear       Int // ปีที่ยื่นภาษี
  reportStatus  VatReportStatus @default(PENDING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([type, taxMonth, taxYear])
}

enum VatRecordType {
  INPUT // ภาษีซื้อ
  OUTPUT // ภาษีขาย
}

enum VatReportStatus {
  PENDING // รอรายงาน
  REPORTED // รายงานแล้ว
}

// ============================================
// ภาษีหัก ณ ที่จ่าย / Withholding Tax
// ============================================
model WithholdingTax {
  id           String          @id @default(cuid())
  type         WhtType // ประเภท
  documentNo   String // เลขที่หนังสือรับรอง
  documentDate DateTime // วันที่
  documentType String? // ประเภทเอกสาร
  referenceId  String? // ID เอกสารอ้างอิง
  payeeId      String? // ID ผู้ถูกหักภาษี
  payeeName    String // ชื่อผู้ถูกหักภาษี
  payeeTaxId   String? // เลขประจำตัวผู้เสียภาษี
  payeeAddress String? // ที่อยู่ผู้ถูกหักภาษี
  description  String? // รายการ
  incomeType   String? // ประเภทเงินได้
  incomeAmount Float           @default(0) // จำนวนเงินที่จ่าย
  whtRate      Float           @default(3) // อัตราภาษีหัก ณ ที่จ่าย
  whtAmount    Float           @default(0) // ภาษีที่หัก
  taxMonth     Int // เดือนที่ยื่นภาษี
  taxYear      Int // ปีที่ยื่นภาษี
  reportStatus WhtReportStatus @default(PENDING)
  notes        String? // หมายเหตุ
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([type, taxMonth, taxYear])
}

enum WhtType {
  PND3 // ภงด.3 (เงินเดือน/ค่าจ้าง)
  PND53 // ภงด.53 (ค่าบริการ/ค่าเช่า)
}

enum WhtReportStatus {
  PENDING // รอรายงาน
  REPORTED // รายงานแล้ว
}

// ============================================
// งบการเงิน / Financial Reports
// ============================================
model FinancialReport {
  id        String     @id @default(cuid())
  type      ReportType // ประเภทรายงาน
  name      String // ชื่อรายงาน
  startDate DateTime // วันที่เริ่ม
  endDate   DateTime // วันที่สิ้นสุด
  data      String // ข้อมูล JSON
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum ReportType {
  TRIAL_BALANCE // งบทดลอง
  BALANCE_SHEET // งบดุล
  INCOME_STATEMENT // งบกำไรขาดทุน
  GENERAL_LEDGER // สมุดบัญชีแยกประเภท
  AGING_AR // รายงานลูกหนี้ตามอายุหนี้
  AGING_AP // รายงานเจ้าหนี้ตามอายุหนี้
  VAT_REPORT // รายงานภาษีมูลค่าเพิ่ม
  WHT_REPORT // รายงานภาษีหัก ณ ที่จ่าย
}

// ============================================
// ผู้ใช้งาน / Users
// ============================================
model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String // รหัสผ่าน (hashed)
  name           String?
  role           UserRole        @default(USER)
  isActive       Boolean         @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  pettyCashFunds PettyCashFund[]
  dataImports    DataImport[]    @relation("DataImportUser")
  activityLogs   ActivityLog[]
}

enum UserRole {
  ADMIN // ผู้ดูแลระบบ
  ACCOUNTANT // นักบัญชี
  USER // ผู้ใช้ทั่วไป
  VIEWER // ผู้ดูเท่านั้น
}

// ============================================
// เลขที่เอกสาร / Document Numbering
// ============================================
model DocumentNumber {
  id           String   @id @default(cuid())
  type         String   @unique // ประเภทเอกสาร
  prefix       String // คำนำหน้า
  currentNo    Int      @default(0) // เลขที่ปัจจุบัน
  format       String   @default("{prefix}{yyyy}{mm}-{0000}") // รูปแบบ
  resetMonthly Boolean  @default(true) // เริ่มใหม่ทุกเดือน
  resetYearly  Boolean  @default(false) // เริ่มใหม่ทุกปี
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// การจับคู่รายการ / Reconciliation
// ============================================
model Reconciliation {
  id          String               @id @default(cuid())
  type        ReconciliationType // ประเภท
  date        DateTime // วันที่
  reference   String? // เอกสารอ้างอิง
  debitId     String? // ID รายการเดบิต
  debitType   String? // ประเภทรายการเดบิต
  creditId    String? // ID รายการเครดิต
  creditType  String? // ประเภทรายการเครดิต
  amount      Float                @default(0) // จำนวนเงิน
  status      ReconciliationStatus @default(PENDING)
  matchedAt   DateTime? // วันที่จับคู่
  matchedById String? // ผู้จับคู่
  notes       String? // หมายเหตุ
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

enum ReconciliationType {
  BANK // กระทบยอดธนาคาร
  AR_PAYMENT // จับคู่รับชำระ
  AP_PAYMENT // จับคู่จ่ายชำระ
}

enum ReconciliationStatus {
  PENDING // รอจับคู่
  MATCHED // จับคู่แล้ว
  UNMATCHED // ไม่ตรงกัน
}

// ============================================
// การเชื่อมต่อระบบภายนอก (Headless API Access)
// ============================================
model ApiToken {
  id         String    @id @default(cuid())
  name       String // e.g., "POS-BKK-01" or "HR-System"
  tokenHash  String    @unique
  scopes     String // e.g., "invoice:write, stock:read"
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  isActive   Boolean   @default(true)
}

// ============================================
// คลังสินค้าและสินค้าคงคลัง (Inventory & Stock)
// ============================================
model InventoryConfig {
  id                    String   @id @default("default") // Singleton
  stockMovementTrigger  String   @default("ON_ISSUE") // "ON_ISSUE" | "ON_CREATE"
  enableMultiCurrency   Boolean  @default(false)
  defaultCostingMethod  String   @default("WEIGHTED_AVERAGE") // "FIFO" | "WEIGHTED_AVERAGE"
  defaultWarehouseId    String?
  autoCreateCOGSJournal Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}

model Warehouse {
  id             String          @id @default(cuid())
  code           String          @unique // รหัสคลัง
  name           String // ชื่อคลัง
  type           WarehouseType   @default(MAIN)
  location       String? // ที่ตั้ง
  isActive       Boolean         @default(true)
  notes          String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  zones          WarehouseZone[]
  balances       StockBalance[]
  stockMovements StockMovement[]
  stockTakes     StockTake[]
}

model WarehouseZone {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  code        String // รหัสโซน e.g., A1, B2
  name        String // ชื่อโซน
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, code])
}

model StockBalance {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Float     @default(0) // จำนวนคงเหลือ
  unitCost    Float     @default(0) // ต้นทุนต่อหน่วย (Weighted Average)
  totalCost   Float     @default(0) // ต้นทุนรวม
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model StockMovement {
  id            String       @id @default(cuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  warehouseId   String
  warehouse     Warehouse    @relation(fields: [warehouseId], references: [id])
  type          MovementType // ประเภทการเคลื่อนไหว
  quantity      Float // จำนวน (บวก/ลบ)
  unitCost      Float // ต้นทุนต่อหน่วย
  totalCost     Float // ต้นทุนรวม
  date          DateTime
  referenceId   String? // อ้างอิงเอกสาร (Invoice ID, Purchase ID, Transfer ID)
  referenceNo   String? // เลขที่เอกสารอ้างอิง
  sourceChannel String? // ช่องทางที่มา
  notes         String?
  createdById   String?
  createdAt     DateTime     @default(now())
  // Multi-currency support
  currency      String?      @default("THB")
  exchangeRate  Float?       @default(1.0)
  foreignCost   Float?
}

model StockTransfer {
  id              String              @id @default(cuid())
  transferNo      String              @unique
  date            DateTime
  fromWarehouseId String
  toWarehouseId   String
  status          TransferStatus      @default(DRAFT)
  requestedById   String?
  approvedById    String?
  notes           String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  lines           StockTransferLine[]
}

model StockTransferLine {
  id         String        @id @default(cuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  quantity   Float
  notes      String?
}

model StockTake {
  id              String           @id @default(cuid())
  stockTakeNumber String           @unique
  warehouseId     String
  warehouse       Warehouse        @relation(fields: [warehouseId], references: [id])
  status          StockTakeStatus  @default(DRAFT)
  takeDate        DateTime
  createdBy       String
  createdByName   String?
  approvedBy      String?
  approvedByName  String?
  approvedAt      DateTime?
  lines           StockTakeLine[]
  journalEntryId  String?          @unique
  journalEntry    JournalEntry?    @relation("StockTakeJournal", fields: [journalEntryId], references: [id])
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([warehouseId])
  @@index([status])
  @@index([takeDate])
}

model StockTakeLine {
  id            String    @id @default(cuid())
  stockTakeId   String
  stockTake     StockTake @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  expectedQty   Float
  actualQty     Float
  varianceQty   Float
  varianceValue Float
  costPerUnit   Float
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([stockTakeId])
  @@index([productId])
}

model ProductCostHistory {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  date        DateTime
  oldUnitCost Float
  newUnitCost Float
  reason      String?
  referenceId String?
  createdAt   DateTime @default(now())
}

enum WarehouseType {
  MAIN
  BRANCH
  VAN
}

enum MovementType {
  RECEIVE
  ISSUE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUST
  RETURN
  INITIAL
}

enum TransferStatus {
  DRAFT
  REQUESTED
  APPROVED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum StockTakeStatus {
  DRAFT
  IN_PROGRESS
  PENDING_APPROVAL
  APPROVED
  POSTED
  CANCELLED
}

// ============================================
// ทะเบียนทรัพย์สิน และ ค่าเสื่อมราคา (Fixed Assets)
// ============================================
model Asset {
  id                  String                 @id @default(cuid())
  code                String                 @unique
  name                String
  purchaseDate        DateTime
  purchaseCost        Float
  salvageValue        Float                  @default(1.0) // ค่าซาก 1 บาท
  usefulLifeYears     Int
  depreciationRate    Float
  glAccountId         String // บัญชีสินทรัพย์
  accumDepAccountId   String // บัญชีค่าเสื่อมราคาสะสม
  depExpenseAccountId String // บัญชีค่าเสื่อมราคา
  isActive            Boolean                @default(true)
  metadata            Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  schedules           DepreciationSchedule[]
}

model DepreciationSchedule {
  id             String   @id @default(cuid())
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id])
  date           DateTime // สิ้นเดือน
  amount         Float
  accumulated    Float
  netBookValue   Float
  journalEntryId String? // เลขที่บันทึกบัญชีที่ Post ไป GL
  posted         Boolean  @default(false)
  createdAt      DateTime @default(now())
}

// ============================================
// ทะเบียนคุมเช็ค และ ธนาคาร (Banking & Cheques)
// ============================================
model BankAccount {
  id              String               @id @default(cuid())
  code            String               @unique
  bankName        String
  branchName      String
  accountNumber   String
  accountName     String
  glAccountId     String
  isActive        Boolean              @default(true)
  metadata        Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  cheques         Cheque[]
  receipts        Receipt[]
  payments        Payment[]          @relation("PaymentBankAccount")
  reconciliations BankReconciliation[]
}

model Cheque {
  id               String              @id @default(cuid())
  chequeNo         String              @unique
  type             ChequeType // RECEIVE, PAY
  bankAccountId    String
  bankAccount      BankAccount         @relation(fields: [bankAccountId], references: [id])
  dueDate          DateTime
  amount           Float
  payeeName        String?
  status           ChequeStatus // ON_HAND, DEPOSITED, CLEARED, BOUNCED, CANCELLED
  documentRef      String? // Links to Receipt / Payment
  clearedDate      DateTime?
  journalEntryId   String? // ID บันทึกบัญชีเมื่อเช็คผ่าน
  journalEntry     JournalEntry?  @relation("ChequeJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  isReconciled     Boolean             @default(false)
  reconciliationId String?
  reconciliation   BankReconciliation? @relation(fields: [reconciliationId], references: [id])
  paymentId        String?
  payment          Payment?            @relation("PaymentCheque", fields: [paymentId], references: [id])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

enum ChequeType {
  RECEIVE
  PAY
}

enum ChequeStatus {
  ON_HAND
  DEPOSITED
  CLEARED
  BOUNCED
  CANCELLED
}

// Bank Reconciliation
model BankReconciliation {
  id               String               @id @default(cuid())
  bankAccountId    String
  bankAccount      BankAccount          @relation(fields: [bankAccountId], references: [id])
  statementDate    DateTime // วันที่รายการเดินบัญชี
  statementBalance Float                @default(0) // ยอดเงินตามรายการเดินบัญชี
  bookBalance      Float                @default(0) // ยอดเงินตามสมุดบัญชี
  difference       Float                @default(0) // ผลต่าง (statement - book)
  status           ReconciliationStatus @default(PENDING)
  reconciledAt     DateTime?
  reconciledById   String?
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  cheques          Cheque[]
}

// ============================================
// เงินสดย่อย (Petty Cash)
// ============================================
model PettyCashFund {
  id             String             @id @default(cuid())
  code           String             @unique
  name           String
  custodianId    String
  custodian      User               @relation(fields: [custodianId], references: [id])
  glAccountId    String
  maxAmount      Float
  currentBalance Float
  isActive       Boolean            @default(true)
  metadata       Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  vouchers       PettyCashVoucher[]
}

model PettyCashVoucher {
  id                 String        @id @default(cuid())
  voucherNo          String        @unique
  fundId             String
  fund               PettyCashFund @relation(fields: [fundId], references: [id])
  date               DateTime
  amount             Float
  payee              String
  description        String
  glExpenseAccountId String
  journalEntryId     String?
  journalEntry       JournalEntry?  @relation("PettyCashVoucherJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  isReimbursed       Boolean       @default(false)
  createdAt          DateTime      @default(now())
}

// ============================================
// ระบบเงินเดือน (Payroll)
// ============================================
model Employee {
  id               String    @id @default(cuid())
  employeeCode     String    @unique
  externalRefId    String?   @unique // Link to future full-HR System
  firstName        String
  lastName         String
  idCardNumber     String?
  hireDate         DateTime
  baseSalary       Float // Decimal (Satang)
  position         String?
  department       String?
  socialSecurityNo String?
  taxId            String?
  bankAccountNo    String?
  bankName         String?
  isActive         Boolean   @default(true)
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  payrolls         Payroll[]
}

model PayrollRun {
  id              String        @id @default(cuid())
  runNo           String        @unique // PR202603-001
  periodMonth     Int
  periodYear      Int
  paymentDate     DateTime
  totalBaseSalary Float
  totalAdditions  Float
  totalDeductions Float
  totalSsc        Float // Employer + Employee portions
  totalTax        Float
  totalNetPay     Float
  status          PayrollStatus // DRAFT, APPROVED, PAID
  journalEntryId  String? // Linked to GL Posting
  journalEntry    JournalEntry?  @relation("PayrollRunJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payrolls        Payroll[]
}

model Payroll {
  id             String     @id @default(cuid())
  payrollRunId   String
  payrollRun     PayrollRun @relation(fields: [payrollRunId], references: [id])
  employeeId     String
  employee       Employee   @relation(fields: [employeeId], references: [id])
  baseSalary     Float
  additions      Float // OT, Bonus
  deductions     Float // Leave without pay
  socialSecurity Float // Deducted from employee (usually 5% capped at 750)
  withholdingTax Float // PND 1
  netPay         Float
  payslipUrl     String?
  createdAt      DateTime   @default(now())
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

// ============================================
// ประวัติการนำเข้าข้อมูล (Data Import History)
// ============================================
model DataImport {
  id              String   @id @default(cuid())
  dataType        String // customers, vendors, products, accounts
  fileName        String
  fileType        String // csv, json
  totalRecords    Int
  createdCount    Int
  updatedCount    Int
  errorCount      Int
  status          ImportStatus @default(COMPLETED)
  errorMessage    String?
  importedById    String?
  importedBy      User?    @relation("DataImportUser", fields: [importedById], references: [id])
  errorDetails    Json? // Detailed error information
  createdAt       DateTime @default(now())
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// บันทึกกิจกรรม (Activity Log)
// ============================================
model ActivityLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  action       String // LOGIN, LOGOUT, CREATE, UPDATE, DELETE, POST, VIEW, EXPORT, etc.
  module       String // invoices, payments, inventory, banking, assets, payroll, petty-cash, etc.
  recordId     String? // ID of affected record
  details      Json? // Additional context (JSON data)
  ipAddress    String?
  status       String // success, failed
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
  @@index([status])
}

// ============================================
// รายงานอัตโนมัติตามกำหนดเวลา (Scheduled Reports)
// ============================================
model ScheduledReport {
  id          String   @id @default(cuid())
  name        String
  reportType  String
  schedule    String // daily, weekly, monthly, quarterly, custom
  dayOfWeek   Int? // 0-6 for weekly (Sunday=0)
  dayOfMonth  Int? // 1-31 for monthly
  monthOfYear Int? // 1-12 for quarterly
  time        String // HH:MM format
  enabled     Boolean @default(true)
  parameters  Json // Report parameters as JSON (filters, date ranges, etc.)
  recipients  String // Comma-separated emails
  outputFormat String @default("PDF") // PDF, EXCEL
  emailSubject String?
  emailBody    String?
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  runs         ScheduledReportRun[]
}

model ScheduledReportRun {
  id               String    @id @default(cuid())
  scheduledReportId String
  scheduledReport  ScheduledReport @relation(fields: [scheduledReportId], references: [id], onDelete: Cascade)
  status           String // success, failed
  runAt            DateTime
  errorMessage     String?
  fileUrl          String?
  fileSize         Int? // File size in bytes
  generatedRecords Int? // Number of records generated
  createdAt        DateTime  @default(now())

  @@index([scheduledReportId])
  @@index([status])
  @@index([runAt])
}
