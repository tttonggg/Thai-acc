    "csrf-csrf": "^4.0.3",
    "dataloader": "^2.2.3",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.2",
    "graphql": "^16.13.1",
    "graphql-tag": "^2.12.6",
    "idb-keyval": "^6.2.2",
    "input-otp": "^1.4.2",
    "jspdf": "^4.2.0",
