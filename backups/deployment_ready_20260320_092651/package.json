{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "npm run db:select-schema && next build && npm run build:standalone",
    "build:standalone": "cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/ && node scripts/build-production.js && cd .next/standalone && npm install --production --legacy-peer-deps && cd ../.. && echo 'Build complete! Standalone directory ready.' && echo 'IMPORTANT: Update .next/standalone/.env with absolute DATABASE_URL path'",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "start:node": "NODE_ENV=production node .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:visual": "playwright test e2e/visual-regression.spec.ts",
    "test:e2e:mobile": "playwright test e2e/mobile-responsive.spec.ts --project='Mobile Chrome' --project='Mobile Safari'",
    "test:e2e:performance": "playwright test e2e/performance.spec.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:quick": "./scripts/test-quick.sh",
    "test:full": "./scripts/test-full.sh",
    "test:module": "./scripts/test-module.sh",
    "test:verify-db": "./scripts/verify-database.sh",
    "test:master": "ts-node tests/master-test-runner.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:lighthouse": "lhci autorun",
    "test:percy": "percy exec -- playwright test e2e/visual-regression.spec.ts",
    "test:smoke": "./scripts/test-automation.sh smoke",
    "test:automated": "./scripts/test-automation.sh",
    "test:schedule": "./scripts/test-scheduler.sh",
    "test:clean": "./scripts/test-automation.sh clean",
    "test:report": "./scripts/test-automation.sh report",
    "db:prepare-schemas": "node scripts/prepare-schemas.js",
    "db:select-schema": "node prisma/schema-loader.js",
    "db:push": "npm run db:select-schema && prisma db push",
    "db:generate": "npm run db:select-schema && prisma generate",
    "db:migrate": "npm run db:select-schema && prisma migrate dev",
    "db:reset": "npm run db:select-schema && prisma migrate reset",
    "seed": "ts-node prisma/seed.ts",
    "seed:fresh": "ts-node prisma/reset-db.ts && npm run seed",
    "docker:build": "docker build -t thai-erp:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env thai-erp:latest",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:compose:logs": "docker-compose logs -f",
    "k8s:deploy": "helm upgrade --install thai-erp ./infrastructure/helm -n thai-erp",
    "k8s:delete": "helm uninstall thai-erp -n thai-erp",
    "security:scan": "./scripts/security/scan-secrets.sh",
    "security:sbom": "./scripts/security/generate-sbom.sh",
    "security:deps": "./scripts/security/dependency-check.sh",
    "ci:all": "npm run lint && npm run type-check && npm run test:coverage && npm run build",
    "prepare": "husky install"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
