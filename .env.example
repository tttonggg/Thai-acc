# ===========================================
# Thai Accounting ERP - Environment Variables
# ===========================================

# Database
DATABASE_URL="file:./prisma/dev.db"

# NextAuth Authentication
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Encryption
ENCRYPTION_KEY="32-character-hex-string-here-abcdef0123456789abcdef"

# Rate Limiting Bypass (for development only)
BYPASS_RATE_LIMIT="false"
BYPASS_CSRF="false"

# Sentry Error Tracking (optional)
# SENTRY_DSN="https://example@sentry.io/project"

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# Database Connection Pool (for PostgreSQL)
# DB_MAX_CONNECTIONS="50"
# DB_MIN_CONNECTIONS="10"
# DB_CONNECTION_TIMEOUT="30"
# DB_IDLE_TIMEOUT="900"
# DB_MAX_LIFETIME="3600"

# Logging
# LOG_LEVEL="info" # debug, info, warn, error
# LOG_FORMAT="json" # json, pretty

# Exchange Rate API (optional - for currency conversion)
# EXCHANGE_RATE_API_KEY="your-api-key-here"

# ===========================================
# PUBLIC ENVIRONMENT VARIABLES (NEXT_PUBLIC_)
# ===========================================
# These are exposed to the browser - only use for non-sensitive config

# NEXT_PUBLIC_APP_VERSION="1.0.0"
# NEXT_PUBLIC_BUILD_HASH="dev"
# NEXT_PUBLIC_BUILD_TIME=""
# NEXT_PUBLIC_WS_ENABLED="false"
# NEXT_PUBLIC_WS_URL="ws://localhost:3001"
